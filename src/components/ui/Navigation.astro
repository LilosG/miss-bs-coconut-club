---
import navData from '../../data/nav.json';
import siteProfile from '../../data/site-profile.json';

const navItems = navData.main;
const ctas = navData.ctas;
const phoneDisplay = siteProfile.seo.telephone;
const phoneHref = `tel:+1${phoneDisplay.replace(/\D/g, '')}`;
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex h-20 items-center justify-between">
      <a href="/" id="nav-logo" class="block">
        <img
          src="/images/miss-bs-coconut-club-logo-white.webp"
          alt="Miss Bs Coconut Club"
          class="h-12 w-auto transition-all duration-300"
          id="nav-logo-img"
        />
      </a>
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navItems.map(item => (
          <a href={item.href} class="nav-link text-xs font-semibold tracking-[0.15em] uppercase text-coastal-bg-pure/80 hover:text-coastal-bg-pure transition-colors duration-200">
            {item.label}
          </a>
        ))}
      </nav>
      <div class="hidden md:flex items-center gap-4">
        <a href={phoneHref} class="nav-link text-xs font-semibold tracking-[0.15em] uppercase text-coastal-bg-pure/80 hover:text-coastal-bg-pure transition-colors duration-200">
          {phoneDisplay}
        </a>
        {ctas.map(cta => (
          cta.style === 'secondary' ? (
            <a id="nav-cta-order" href={cta.href} target={cta.external ? '_blank' : undefined} rel={cta.external ? 'noopener noreferrer' : undefined} class="nav-cta px-5 py-2.5 text-xs font-bold tracking-widest uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-200">
              {cta.label}
            </a>
          ) : (
            <a id="nav-cta-reserve" href={cta.href} target={cta.external ? '_blank' : undefined} rel={cta.external ? 'noopener noreferrer' : undefined} class="px-5 py-2.5 text-xs font-bold tracking-widest uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
              {cta.label}
            </a>
          )
        ))}
      </div>
      <button
        id="mobile-menu-btn"
        class="md:hidden text-coastal-bg-pure p-2"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-coastal-bg-sand flex flex-col items-center justify-center gap-7 translate-x-full transition-transform duration-300 md:hidden"
  aria-hidden="true"
>
  <button id="mobile-menu-close" class="absolute top-6 right-6 text-coastal-text-main p-2" aria-label="Close menu">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <img src="/images/miss-bs-coconut-club-logo-white.webp" alt="Miss B's Coconut Club" class="h-12 w-auto mb-4 invert" />
  <nav class="flex flex-col items-center gap-6" aria-label="Mobile navigation">
    {navItems.map(item => (
      <a href={item.href} class="text-2xl font-semibold tracking-[0.1em] uppercase text-coastal-text-main hover:text-coastal-coral transition-colors duration-200">
        {item.label}
      </a>
    ))}
  </nav>
  <div class="flex flex-col gap-3 mt-4 w-48">
    {ctas.map(cta => (
      cta.style === 'secondary' ? (
        <a href={cta.href} target={cta.external ? '_blank' : undefined} rel={cta.external ? 'noopener noreferrer' : undefined} class="text-center px-5 py-3 text-xs font-bold tracking-widest uppercase border border-coastal-text-main/40 text-coastal-text-main hover:bg-coastal-text-main hover:text-coastal-bg-pure transition-all duration-200">
          {cta.label}
        </a>
      ) : (
        <a href={cta.href} target={cta.external ? '_blank' : undefined} rel={cta.external ? 'noopener noreferrer' : undefined} class="text-center px-5 py-3 text-xs font-bold tracking-widest uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
          {cta.label}
        </a>
      )
    ))}
  </div>
  <a href={phoneHref} class="flex items-center gap-2 mt-2 text-coastal-text-main text-xs font-semibold tracking-[0.15em] uppercase">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L9.483 3.102a1.125 1.125 0 00-1.091-.852H7.5A2.25 2.25 0 005.25 4.5v2.25z" />
    </svg>
    {phoneDisplay}
  </a>
</div>

<script>
  const nav = document.getElementById("site-nav");
  const logoImg = document.getElementById("nav-logo-img");
  const orderCta = document.getElementById("nav-cta-order");
  const navLinks = document.querySelectorAll(".nav-link");

  window.addEventListener("scroll", () => {
    if (!nav) return;
    if (window.scrollY > 80) {
      nav.classList.remove("bg-transparent");
      nav.classList.add("bg-coastal-bg-pure", "shadow-sm", "border-b", "border-coastal-text-muted/10");
      if (logoImg) logoImg.style.filter = "invert(1)";
      navLinks.forEach(a => {
        a.classList.remove("text-coastal-bg-pure/80", "hover:text-coastal-bg-pure");
        a.classList.add("text-coastal-text-muted", "hover:text-coastal-text-main");
      });
      if (orderCta) {
        orderCta.classList.remove("border-coastal-bg-pure/50", "text-coastal-bg-pure", "hover:bg-coastal-bg-pure", "hover:text-coastal-text-main");
        orderCta.classList.add("border-coastal-text-main", "text-coastal-text-main", "hover:bg-coastal-text-main", "hover:text-coastal-bg-pure");
      }
    } else {
      nav.classList.add("bg-transparent");
      nav.classList.remove("bg-coastal-bg-pure", "shadow-sm", "border-b", "border-coastal-text-muted/10");
      if (logoImg) logoImg.style.filter = "invert(0)";
      navLinks.forEach(a => {
        a.classList.add("text-coastal-bg-pure/80", "hover:text-coastal-bg-pure");
        a.classList.remove("text-coastal-text-muted", "hover:text-coastal-text-main");
      });
      if (orderCta) {
        orderCta.classList.add("border-coastal-bg-pure/50", "text-coastal-bg-pure", "hover:bg-coastal-bg-pure", "hover:text-coastal-text-main");
        orderCta.classList.remove("border-coastal-text-main", "text-coastal-text-main", "hover:bg-coastal-text-main", "hover:text-coastal-bg-pure");
      }
    }
  });

  const menuBtn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");

  function openMenu() {
    menu?.classList.remove("translate-x-full");
    menu?.setAttribute("aria-hidden", "false");
    menuBtn?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    menu?.classList.add("translate-x-full");
    menu?.setAttribute("aria-hidden", "true");
    menuBtn?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  menuBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  menu?.querySelectorAll("a").forEach(link => link.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeMenu(); });
</script>

