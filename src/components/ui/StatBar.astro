---
interface Stat {
  value: string
  label: string
}

interface Props {
  items: Stat[]
  cellPy?: 'py-5' | 'py-8'
}

const { items, cellPy = 'py-8' } = Astro.props;

const cellPyMap = {
  'py-5': 'py-5',
  'py-8': 'py-8',
} as const;

const cellPyClass = cellPyMap[cellPy];
---

<section class="bg-coastal-text-main">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-coastal-bg-pure/10">
      {items.map((stat) => (
        <div class={`flex flex-col items-center justify-center ${cellPyClass} px-4 gap-1`}>
          <span class="font-serif text-2xl font-light italic text-coastal-coral" set:html={stat.value} />
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60" set:html={stat.label} />
        </div>
      ))}
    </div>
  </div>
</section>
