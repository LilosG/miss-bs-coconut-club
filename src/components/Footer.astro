---
import { getEntry } from 'astro:content';
import { GPH_NETWORK, GRIND_AND_PROSPER_URL } from '../data/gphNetwork';

const footer = (await getEntry('footer', 'footer'))!.data;
const siteProfile = (await getEntry('siteSettings', 'site'))!.data;
const footerLinks = footer.links;

const portfolio = GPH_NETWORK.filter((v) => v.url !== siteProfile.domain);
---

<footer class="bg-coastal-text-main text-coastal-bg-sand">

  <!-- Gold rule top -->
  <div class="h-px bg-gradient-to-r from-transparent via-coastal-coral/40 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12 border-b border-coastal-text-muted/20">

      <!-- Brand column -->
      <div class="flex flex-col gap-4">
        <a href="/" class="block w-fit">
          <img
            src={footer.logo.src}
            alt={footer.logo.alt}
            class="h-14 w-auto"
          />
        </a>
        <p class="text-sm text-coastal-text-muted leading-relaxed max-w-[28ch]" set:html={`\n${footer.description}\n`} />
        <a href={"tel:" + siteProfile.phone} class="text-sm text-coastal-gold-accent hover:text-coastal-bg-sand transition-colors duration-200 w-fit">
          {siteProfile.phone}
        </a>
      </div>

      <!-- Nav column -->
      <nav class="flex flex-col gap-3">
        <p class="text-[10px] font-bold tracking-[0.28em] uppercase text-coastal-coral mb-1">{footer.exploreHeading}</p>
        {footerLinks.map((item: { label: string; href: string }) => (
          <a href={item.href} class="text-sm text-coastal-text-muted hover:text-coastal-gold-accent transition-colors duration-200 w-fit">
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Hours + Address column -->
      <div class="flex flex-col gap-3">
        <p class="text-[10px] font-bold tracking-[0.28em] uppercase text-coastal-coral mb-1">{footer.visitHeading}</p>
        <address class="not-italic flex flex-col gap-1">
          <span class="text-sm text-coastal-bg-sand">{siteProfile.address.streetAddress}</span>
          <span class="text-sm text-coastal-text-muted">{siteProfile.address.addressLocality}, {siteProfile.address.addressRegion} {siteProfile.address.postalCode}</span>
        </address>
        <div class="flex flex-col gap-1 mt-2">
          {siteProfile.hours.general.map((h: { label: string; display: string }) => (
            <span class="text-sm text-coastal-text-muted">{h.label}: {h.display}</span>
          ))}
          <span class="text-xs text-coastal-coral/80 mt-1">{footer.brunchHours}</span>
        </div>
      </div>

    </div>

    <!-- GPH Network row -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8 pt-6 pb-6 border-b border-coastal-text-muted/20">
      <a href={GRIND_AND_PROSPER_URL} target="_blank" rel="noopener noreferrer"
        class="text-[10px] font-bold tracking-[0.28em] uppercase text-coastal-text-muted/60 hover:text-coastal-gold-accent transition-colors whitespace-nowrap"
        set:html={`\n${footer.hospitalityLabel}\n`}
      />
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        {portfolio.map((v) => (
          <a href={v.url} target="_blank" rel="noopener noreferrer"
            class="text-xs text-coastal-text-muted/50 hover:text-coastal-bg-sand transition-colors">
            {v.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-coastal-text-muted" set:html={`\n&copy; ${new Date().getFullYear()} ${footer.copyrightName}\n`} />
      <p class="text-xs text-coastal-text-muted" set:html={`\n${siteProfile.address.streetAddress} · Mission Beach, ${siteProfile.address.addressLocality}\n`} />
      <a href={footer.credit.href} target="_blank" rel="noopener noreferrer"
        class="text-[13px] text-coastal-text-muted hover:text-coastal-gold-accent transition-colors"
        set:html={`\n${footer.credit.label}\n`}
      />
    </div>

  </div>
</footer>
