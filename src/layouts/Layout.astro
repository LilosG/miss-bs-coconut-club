---
import LocalSEO from '../components/core/LocalSEO.astro';
import Navigation from '../components/ui/Navigation.astro';
import siteProfile from '../data/site-profile.json';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const { fonts } = siteProfile.designSystem;

const footerLinks = [
  { label: 'Menu', href: '/menu' },
  { label: 'Brunch', href: '/brunch' },
  { label: 'The Space', href: '/space' },
  { label: 'Private Events', href: '/private-events' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth font-sans font-normal bg-coastal-bg-sand text-coastal-text-main">
  <head>
    <LocalSEO title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Navigation />
    <main class="flex-grow">
      <slot />
    </main>
    <footer class="bg-coastal-text-main text-coastal-bg-sand py-12 border-t border-coastal-text-muted/20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
          <div class="flex flex-col gap-3">
            <span class="font-serif tracking-wide text-2xl font-black tracking-wider text-coastal-bg-sand uppercase">
              {siteProfile.venueName}
            </span>
            <p class="text-sm text-coastal-text-muted max-w-xs leading-relaxed">
              {siteProfile.seo.streetAddress}, {siteProfile.seo.addressLocality}, {siteProfile.seo.addressRegion} {siteProfile.seo.postalCode}
            </p>
            <a href={"tel:" + siteProfile.seo.telephone} class="text-sm text-coastal-gold-accent hover:text-coastal-bg-sand transition-colors duration-200">
              {siteProfile.seo.telephone}
            </a>
          </div>
          <nav class="flex flex-col gap-2">
            {footerLinks.map(item => (
              <a href={item.href} class="text-sm text-coastal-text-muted hover:text-coastal-gold-accent transition-colors duration-200">
                {item.label}
              </a>
            ))}
          </nav>
        </div>
        <div class="mt-12 pt-6 border-t border-coastal-text-muted/20 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-xs text-coastal-text-muted">
            {new Date().getFullYear()} {siteProfile.venueName}. All rights reserved.
          </p>
          <p class="text-xs text-coastal-text-muted">
            {siteProfile.seo.addressLocality}, {siteProfile.seo.addressRegion} - {siteProfile.seo.priceRange}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
