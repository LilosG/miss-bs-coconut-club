  "brunchFaq": [
    {
      "q": "What are brunch hours?",
      "a": "Brunch is served daily. Monday through Friday from 10am to 2pm, and Saturday and Sunday from 9am to 2pm."
    },
    {
      "q": "Are mimosas available during brunch?",
      "a": "Yes. Mimosas are poured from our 24 copper flamingo taps and available by the glass throughout brunch service."
    },
    {
      "q": "Do I need a reservation?",
      "a": "Walk-ins are welcome but we strongly recommend reservations for brunch, especially on weekends."
    },
    {
      "q": "Is the patio open for brunch?",
      "a": "Yes. The full outdoor patio and bar area is open for brunch service weather permitting."
    },
    {
      "q": "Is the full bar open during brunch?",
      "a": "The full bar program is available during brunch hours, including tropical cocktails, Bloody Marys, beer, and wine."
    }
  ],
