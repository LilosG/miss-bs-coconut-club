---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import { getCollection, getEntry } from 'astro:content';

const siteProfile = (await getEntry('siteSettings', 'site'))!.data;
const page = (await getEntry('faqPage', 'faq'))!.data;
const happyHourActive = siteProfile.hours?.happyHour?.find((h: { closed?: boolean }) => !h.closed);
const happyHourOffDays = siteProfile.hours?.happyHour?.find((h: { closed?: boolean }) => h.closed);
const faqs = (await getCollection('generalFaqs'))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((entry) => entry.data);
const happyHourFaq = faqs.find((faq) => faq.q === page.happyHour.question);
if (happyHourFaq) {
  happyHourFaq.a = happyHourActive
    ? `${page.happyHour.prefix}${happyHourActive.display}, ${happyHourActive.label}${page.happyHour.middle}${happyHourOffDays ? `${page.happyHour.offDaysPrefix}${happyHourOffDays.label}.` : ''}`
    : page.happyHour.closedAnswer;
}

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": a
    }
  }))
};
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema, null, 2)} slot="head" />

  <PageHero
    imageSrc={page.hero.imageSrc}
    imageAlt={page.hero.imageAlt}
    eyebrow={page.hero.eyebrow}
    heading={page.hero.heading}
    subheading={page.hero.subheading}
    minHeight="60vh"
  />

  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.list.eyebrow}</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">{page.list.heading}</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>

      <div class="divide-y divide-coastal-bg-card">
        {faqs.map(({ q, a }) => (
          <details class="group py-6">
            <summary class="flex items-center justify-between gap-6 cursor-pointer list-none">
              <h3 class="font-sans text-base font-semibold text-coastal-text-main leading-snug pr-4">{q}</h3>
              <span class="shrink-0 text-coastal-coral text-xl font-light transition-transform duration-200 group-open:rotate-45">+</span>
            </summary>
            <p class="mt-4 text-coastal-text-muted text-sm leading-relaxed max-w-2xl">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.cta.eyebrow}</p>
        <p class="font-serif text-4xl font-light italic text-coastal-bg-pure" set:html={page.cta.heading} />
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        {page.cta.links?.[0] && <a href={page.cta.links[0].href} class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.cta.links[0].label}\n`} />}
        {page.cta.links?.[1] && <a href={page.cta.links[1].href} class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.cta.links[1].label}\n`} />}
      </div>
    </div>
  </section>

</Layout>
