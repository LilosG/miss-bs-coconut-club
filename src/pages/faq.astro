---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
const faqs = [
  {
    q: "What are Miss B's Coconut Club hours?",
    a: "Miss B's is open Monday through Friday from 10am to 10pm, and Saturday and Sunday from 9am to 10pm. The kitchen closes at 9pm daily, and brunch is served daily until 2pm."
  },
  {
    q: "Do you take walk-ins?",
    a: "Yes. Walk-ins are always welcome at the bar and patio. We strongly recommend reservations for brunch and for groups of 6 or more."
  },
  {
    q: "What are the brunch hours?",
    a: "Brunch is served daily — Monday through Thursday from 11am to 2pm, and Friday through Sunday from 10am to 2pm."
  },
  {
    q: "Do you offer bottomless mimosas?",
    a: "Yes. Bottomless mimosas are available daily during brunch service. Ask your server for details."
  },
  {
    q: "Is the outdoor patio open year-round?",
    a: "The outdoor patio and open-air bar are open year-round, weather permitting. Mission Beach's mild climate means the patio is comfortable most of the year."
  },
  {
    q: "Where is Miss B's Coconut Club located?",
    a: "Miss B's Coconut Club is located at 3704 Mission Blvd, Mission Beach, San Diego, CA 92109 — steps from the Pacific Ocean."
  },
  {
    q: "Is there parking near Miss B's?",
    a: "Street parking is available on Mission Blvd and surrounding streets. Mission Beach is a walkable neighborhood — many guests bike or walk from nearby rentals. Paid lots are also available nearby."
  },
  {
    q: "Can I host a private event at Miss B's?",
    a: "Yes. Miss B's Coconut Club offers full and partial venue buyouts for birthday parties, corporate events, bachelorette parties, rehearsal dinners, and milestone celebrations. The indoor dining room seats up to 60 guests; the outdoor patio accommodates up to 80 guests reception-style."
  },
  {
    q: "How do I book a private event?",
    a: "Submit an inquiry through our contact page. Our events team responds within 24 hours with availability and a custom proposal tailored to your date, headcount, and event type."
  },
  {
    q: "Is Miss B's dog-friendly?",
    a: "Dogs are welcome on the outdoor patio. We love our four-legged guests."
  },
  {
    q: "Is Miss B's kid-friendly?",
    a: "Yes. Families are welcome. Kids are allowed on the patio and in the dining room during daytime service."
  },
  {
    q: "What kind of food does Miss B's serve?",
    a: "Miss B's serves Caribbean-inspired food including tacos, burgers, salads, and brunch plates. The kitchen is open from the start of service through close."
  },
  {
    q: "What cocktails does Miss B's have?",
    a: "Miss B's is known for tropical signature cocktails, frozen drinks, and a 24-tap draft beer system with copper flamingo handles. The full bar program includes craft cocktails, beer, wine, and spirits."
  },
  {
    q: "What is the best bar in Mission Beach?",
    a: "Miss B's Coconut Club is Mission Beach's only open-air bar venue with a full kitchen, outdoor patio, and private event space — all at 3704 Mission Blvd, steps from the Pacific."
  },
  {
    q: "What is the best brunch in Mission Beach?",
    a: "Miss B's brunch is consistently voted one of the best in Mission Beach and Pacific Beach. Bottomless mimosas, tropical cocktails, and a full brunch menu served daily until 2pm."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": a
    }
  }))
};
---

<Layout
  title="FAQ - Hours, Brunch, Private Events &amp; More | Miss B's Coconut Club Mission Beach"
  description="Frequently asked questions about Miss B's Coconut Club in Mission Beach, San Diego. Hours, brunch details, parking, private events, and more."
>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema, null, 2)} slot="head" />

  <PageHero
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp"
    imageAlt="Miss B's Coconut Club teal open-air bar Mission Beach San Diego"
    eyebrow="Everything You Need to Know"
    heading="FAQ"
    subheading="Hours, brunch, private events, parking, and more — answered."
    minHeight="60vh"
  />

  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Common Questions</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">Frequently Asked</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>

      <div class="divide-y divide-coastal-bg-card">
        {faqs.map(({ q, a }) => (
          <details class="group py-6">
            <summary class="flex items-center justify-between gap-6 cursor-pointer list-none">
              <h3 class="font-sans text-base font-semibold text-coastal-text-main leading-snug pr-4">{q}</h3>
              <span class="shrink-0 text-coastal-coral text-xl font-light transition-transform duration-200 group-open:rotate-45">+</span>
            </summary>
            <p class="mt-4 text-coastal-text-muted text-sm leading-relaxed max-w-2xl">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Still Have Questions?</p>
        <p class="font-serif text-4xl font-light italic text-coastal-bg-pure">We're here to help.</p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/contact" class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          Contact Us
        </a>
        <a href="/private-events" class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Private Events
        </a>
      </div>
    </div>
  </section>

</Layout>
