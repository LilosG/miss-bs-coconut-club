---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import PageHero from '../components/ui/PageHero.astro';
import SplitSection from '../components/ui/SplitSection.astro';
import HoverImageGrid from '../components/ui/HoverImageGrid.astro';

const siteProfile = (await getEntry('siteSettings', 'site'))!.data;
const page = (await getEntry('spacePage', 'space'))!.data;
const mapsURL = "https://www.google.com/maps/search/?api=1&query=" + siteProfile.address.streetAddress + " " + siteProfile.address.addressLocality + " " + siteProfile.address.addressRegion;
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
>

  <PageHero
    imageSrc={page.hero.imageSrc}
    imageAlt={page.hero.imageAlt}
    eyebrow={page.hero.eyebrow}
    heading={page.hero.heading}
    subheading={page.hero.subheading}
    overlayVia="via-coastal-text-main/20"
  />

  <!-- THE OUTDOOR BAR — venue-13 shows the bar window open -->
  <SplitSection
    imageSrc={page.sections[0].imageSrc}
    imageAlt={page.sections[0].imageAlt}
    eyebrow={page.sections[0].eyebrow}
    heading={page.sections[0].heading}
    imageLeft={true}
  >
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.sections[0].body[0]}\n`} />
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.sections[0].body[1]}\n`} />
    <a href={page.sections[0].cta.href} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.sections[0].cta.label}\n`} />
  </SplitSection>

  <!-- THE DINING ROOM — venue-07 shows mural and tropical interior -->
  <SplitSection
    imageSrc={page.sections[1].imageSrc}
    imageAlt={page.sections[1].imageAlt}
    eyebrow={page.sections[1].eyebrow}
    heading={page.sections[1].heading}
    sectionBg="bg-coastal-bg-sand"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.sections[1].body[0]}\n`} />
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.sections[1].body[1]}\n`} />
    <a href={page.sections[1].cta.href} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.sections[1].cta.label}\n`} />
  </SplitSection>

  <!-- THE PATIO — venue-03 shows pink umbrellas and exterior -->
  <SplitSection
    imageSrc={page.sections[2].imageSrc}
    imageAlt={page.sections[2].imageAlt}
    eyebrow={page.sections[2].eyebrow}
    heading={page.sections[2].heading}
    imageLeft={true}
    imagePosition="top"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.sections[2].body[0]}\n`} />
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.sections[2].body[1]}\n`} />
    <a href={page.sections[2].cta.href} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.sections[2].cta.label}\n`} />
  </SplitSection>

  <!-- THE FLAMINGO BAR FEATURE — venue-17 copper taps -->
  <section class="relative overflow-hidden min-h-[560px] flex items-center">
    <img
      src={page.taps.imageSrc}
      alt={page.taps.imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main/90 via-coastal-text-main/60 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-20">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.taps.eyebrow}</p>
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.0]" set:html={`\n${page.taps.heading.replaceAll('<br />', '<br>')}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/85 text-base leading-relaxed" set:html={`\n${page.taps.body}\n`} />
      </div>
    </div>
  </section>

  <!-- VENUE PHOTO GRID — 4 images not used in split sections above -->
  <section class="bg-coastal-bg-pure">
    <HoverImageGrid items={page.gallery} />
  </section>

  <!-- LOCATION CTA -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.location.eyebrow}</p>
        <p class="font-serif text-4xl md:text-5xl font-light italic text-coastal-bg-pure">
          {siteProfile.address.streetAddress}
        </p>
        <p class="text-coastal-text-muted text-sm">
          {siteProfile.address.addressLocality}, {siteProfile.address.addressRegion} {siteProfile.address.postalCode}
        </p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href={page.location.ctas[0].href} class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.location.ctas[0].label}\n`} />
        <a href={mapsURL} target="_blank" rel="noopener noreferrer" class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.location.ctas[1].label}\n`} />
      </div>
    </div>
  </section>

</Layout>
