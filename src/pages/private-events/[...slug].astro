---
import Layout from '../../layouts/Layout.astro';
import siteProfile from '../../data/site-profile.json';

const events: Record<string, {
  title: string;
  metaTitle: string;
  description: string;
  eyebrow: string;
  capacity: string;
  body: string[];
  includes: string[];
}> = {
  'birthday-parties': {
    title: 'Birthday Parties',
    metaTitle: 'Birthday Party Venue Mission Beach San Diego | Miss B\'s Coconut Club',
    description: 'Celebrate your birthday at Miss B\'s Coconut Club in Mission Beach, San Diego. Full buyouts, patio sections, and custom cocktail packages at 3704 Mission Blvd.',
    eyebrow: 'Celebrate in Style',
    capacity: 'Up to 80 guests',
    body: [
      'Miss B\'s Coconut Club is the best birthday party venue in Mission Beach — and honestly, one of the best in San Diego. The open-air bar, the tropical dining room, the pink umbrella patio, the copper flamingo taps. It\'s a venue that makes the birthday photos look as good as the night felt.',
      'We offer full venue buyouts, partial section reservations, and patio-only configurations depending on your group size and vibe. Custom cocktail packages and curated menus available for all events.',
    ],
    includes: ['Dedicated event staff', 'Custom cocktail packages', 'Flexible room configuration', 'Custom food menu options', 'Full bar access', '24-hour inquiry response'],
  },
  'corporate-events': {
    title: 'Corporate Events',
    metaTitle: 'Corporate Event Venue Mission Beach San Diego | Miss B\'s Coconut Club',
    description: 'Corporate events and company outings at Miss B\'s Coconut Club in Mission Beach, San Diego. The only outdoor bar venue on Mission Blvd for team events and client entertainment.',
    eyebrow: 'Corporate Events',
    capacity: 'Up to 80 guests',
    body: [
      'Miss B\'s Coconut Club is the corporate event venue that your team will actually be excited about. Not a hotel conference room. Not a generic restaurant private dining setup. A genuine Mission Beach experience at one of San Diego\'s most distinctive venues.',
      'Company outings, client entertainment, team celebrations, and holiday parties. Our events team handles every detail so you can focus on the people in the room.',
    ],
    includes: ['Dedicated event coordinator', 'Custom catering menus', 'Full bar and cocktail packages', 'AV available on request', 'Flexible space configuration', 'Full venue or partial buyouts'],
  },
  'bachelorette-parties': {
    title: 'Bachelorette Parties',
    metaTitle: 'Bachelorette Party Venue Mission Beach San Diego | Miss B\'s Coconut Club',
    description: 'Bachelorette parties at Miss B\'s Coconut Club in Mission Beach, San Diego. Tropical cocktails, flamingo taps, pink umbrellas, and a patio steps from the Pacific.',
    eyebrow: 'The Ultimate Bachelorette',
    capacity: 'Groups of any size',
    body: [
      'If you\'re planning a bachelorette party in San Diego, Miss B\'s Coconut Club is the answer. The tropical cocktails, the copper flamingo taps, the pink fringed umbrellas on the patio, the "In Love With The Coco" sign — it was practically designed for a bachelorette.',
      'Mission Beach location means you\'re steps from the Pacific and within easy reach of Pacific Beach nightlife. We\'ll make sure the group has a reserved section, a cocktail package worth celebrating with, and a night that earns its own highlight reel.',
    ],
    includes: ['Reserved section or full buyout', 'Custom cocktail packages', 'Bottomless mimosas available', 'Dedicated server', 'Custom menu options', 'Photo-worthy backdrop guaranteed'],
  },
  'full-venue-buyouts': {
    title: 'Full Venue Buyouts',
    metaTitle: 'Full Venue Buyout Mission Beach San Diego | Miss B\'s Coconut Club',
    description: 'Full venue buyout at Miss B\'s Coconut Club in Mission Beach, San Diego. The entire bar, dining room, and patio exclusively yours for your event.',
    eyebrow: 'Exclusive Access',
    capacity: 'Up to 80 guests',
    body: [
      'A full Miss B\'s buyout means the entire venue is yours — the open-air bar, the tropical dining room, the fire pit patio, and every copper flamingo tap handle on the wall. The whole thing. Exclusively for your event.',
      'Our team works with you on every detail: custom menu, cocktail program, room configuration, and dedicated staff throughout. This is the ultimate Mission Beach private event experience.',
    ],
    includes: ['Entire venue exclusively yours', 'All three spaces — bar, dining room, patio', 'Full custom menu and cocktail program', 'Dedicated events team and staff', 'Setup and breakdown included', 'Up to 80 guests'],
  },
  'rehearsal-dinners': {
    title: 'Rehearsal Dinners',
    metaTitle: 'Rehearsal Dinner Venue Mission Beach San Diego | Miss B\'s Coconut Club',
    description: 'Rehearsal dinners at Miss B\'s Coconut Club in Mission Beach, San Diego. Casual-upscale, beach-adjacent, and Caribbean-inspired at 3704 Mission Blvd.',
    eyebrow: 'The Night Before',
    capacity: 'Up to 60 seated',
    body: [
      'The night before the wedding should feel like the best kind of night out — somewhere that sets the tone for the celebration ahead. Miss B\'s Coconut Club is casual-upscale, genuinely memorable, and exactly the kind of place people talk about the next day.',
      'Caribbean-inspired menu, full cocktail program, tropical dining room. Seated dinners up to 60 guests. The kind of rehearsal dinner that earns its own toasts.',
    ],
    includes: ['Seated dinner configuration', 'Custom rehearsal dinner menu', 'Full cocktail and wine service', 'Dedicated events staff', 'Private dining room available', 'Flexible timeline'],
  },
  'milestone-celebrations': {
    title: 'Milestone Celebrations',
    metaTitle: 'Milestone Celebration Venue Mission Beach San Diego | Miss B\'s Coconut Club',
    description: 'Milestone celebrations at Miss B\'s Coconut Club in Mission Beach, San Diego. Anniversaries, graduations, retirements, and every reason to celebrate at 3704 Mission Blvd.',
    eyebrow: 'Every Reason to Celebrate',
    capacity: 'Flexible configurations',
    body: [
      'Anniversaries, retirements, graduations, promotions — every milestone deserves a venue that matches the occasion. Miss B\'s Coconut Club is the kind of place people remember, which means your celebration will be remembered too.',
      'We configure the space to suit your group and your vision. Intimate seated dinners, cocktail receptions, or full venue buyouts. Whatever the milestone calls for.',
    ],
    includes: ['Custom event configuration', 'Full menu and cocktail customization', 'Dedicated events coordinator', 'Flexible guest count', 'All venue spaces available', '24-hour inquiry response'],
  },
};

export async function getStaticPaths() {
  return Object.keys({
    'birthday-parties': true,
    'corporate-events': true,
    'bachelorette-parties': true,
    'full-venue-buyouts': true,
    'rehearsal-dinners': true,
    'milestone-celebrations': true,
  }).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const event = events[slug as string];

if (!event) return Astro.redirect('/private-events');
---

<Layout
  title={event.metaTitle}
  description={event.description}
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[70vh] flex items-end overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp"
      alt={"Miss B's Coconut Club " + event.title + " Mission Beach San Diego"}
      class="absolute inset-0 w-full h-full object-cover object-top"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/85 via-coastal-text-main/30 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-16 md:pb-24">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral mb-4">
        {event.eyebrow}
      </p>
      <h1 class="font-serif text-5xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.95] mb-4">
        {event.title}
      </h1>
      <p class="text-coastal-bg-card/80 text-base max-w-xl leading-relaxed">
        {event.description}
      </p>
    </div>
  </section>

  <!-- ─── EVENT DETAIL SPLIT ────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-pure">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[620px]">
      <div class="flex flex-col justify-center px-10 py-20 lg:px-16 xl:px-20 gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          {event.title} at Miss B's
        </p>
        <h2 class="font-serif text-4xl md:text-5xl font-light italic text-coastal-text-main leading-[1.0]">
          Everything You Need<br />for a Perfect Event
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        {event.body.map((para) => (
          <p class="text-coastal-text-muted text-base leading-relaxed">{para}</p>
        ))}
        <a href="/contact" class="self-start mt-2 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
          Submit an Inquiry
        </a>
      </div>
      <div class="relative min-h-[460px] lg:min-h-full">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-13.webp"
          alt={"Miss B's Coconut Club " + event.title + " venue space Mission Beach"}
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="flex flex-col gap-4">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">What's Included</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light italic text-coastal-text-main leading-[1.0]">
          Everything Handled
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed mt-2">
          Our events team takes care of every detail so you can focus on your guests.
        </p>
      </div>
      <ul class="flex flex-col divide-y divide-coastal-text-muted/10">
        {event.includes.map((item) => (
          <li class="flex items-center gap-4 py-4 text-sm text-coastal-text-muted">
            <div class="h-px w-5 bg-coastal-coral shrink-0"></div>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── BACK + CTA ────────────────────────────────────────────────────── -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-8">
      <a href="/private-events" class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-text-muted hover:text-coastal-bg-pure transition-colors duration-200">
        ← All Event Types
      </a>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/contact" class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          Submit an Inquiry
        </a>
        <a href="/space" class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          View the Space
        </a>
      </div>
    </div>
  </section>

</Layout>
