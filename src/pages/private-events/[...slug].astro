---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SplitSection from '../../components/ui/SplitSection.astro';
import ChecklistItems from '../../components/ui/ChecklistItems.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('privateEventTypes');
  return events.map((event) => ({ params: { slug: event.data.slug }, props: { event: event.data } }));
}

const { event } = Astro.props;
const page = (await getEntry('privateEventsIndexPage', 'private-events'))!.data;
---

<Layout
  title={event.metaTitle}
  description={event.description}
>

  <PageHero
    imageSrc={page.detail.heroImage}
    imageAlt={"Miss B's Coconut Club " + event.title + " Mission Beach San Diego"}
    eyebrow={event.eyebrow}
    heading={event.title}
    subheading={event.description}
    minHeight="70vh"
    imagePosition="top"
  />

  <!-- ─── EVENT DETAIL SPLIT ────────────────────────────────────────────── -->
  <SplitSection
    imageSrc={page.detail.splitImage}
    imageAlt={"Miss B's Coconut Club " + event.title + " venue space Mission Beach"}
    eyebrow={event.title + " at Miss B's"}
    heading={page.detail.splitHeading}
    minHeight="620px"
    headingSize="medium"
  >
    {(event.body ?? []).map((para) => (
      <p class="text-coastal-text-muted text-base leading-relaxed">{para}</p>
    ))}
    <a href={page.detail.submitHref} class="self-start mt-2 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.detail.submitLabel}\n`} />
  </SplitSection>

  <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="flex flex-col gap-4">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral" set:html={page.detail.includedEyebrow} />
        <h2 class="font-serif text-4xl md:text-5xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.detail.includedHeading}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed mt-2" set:html={`\n${page.detail.includedBody}\n`} />
      </div>
      <ChecklistItems items={event.includes ?? []} divided={true} />
    </div>
  </section>

  <!-- ─── EVENT INQUIRY FORM ──────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6" id="inquiry">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col gap-4 mb-10">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.detail.bookPrefix}{event.title}</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.detail.submitLabel}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed max-w-lg" set:html={`\n${page.detail.inquiryBody}\n`} />
      </div>
      <iframe
        src="https://www.toasttab.com/invoice/lead?rx=e5c781b0-3ef7-4e6e-acaa-f50c55b15f70&ot=555d2efd-aea1-4bef-ac04-17793cda7ded&form=1"
        style="margin:auto;display:block;border:0;width:100%;height:800px"
        title={page.inquiry.iframeTitle}
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <!-- ─── BACK + CTA ────────────────────────────────────────────────────── -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-8">
      <a href={page.detail.allEventsHref} class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-text-muted hover:text-coastal-bg-pure transition-colors duration-200" set:html={`\n${page.detail.allEventsLabel}\n`} />
      <div class="flex flex-wrap gap-3 justify-center">
        <a href={page.detail.submitHref} class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.detail.submitLabel}\n`} />
        <a href={page.detail.viewSpaceHref} class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.detail.viewSpaceLabel}\n`} />
      </div>
    </div>
  </section>

</Layout>
