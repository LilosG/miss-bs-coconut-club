---
import Layout from '../../layouts/Layout.astro';
import siteProfile from '../../data/site-profile.json';

const eventTypes = [
  {
    slug: 'birthday-parties',
    title: 'Birthday Parties',
    desc: 'Celebrate in the most Mission Beach way possible. Full buyouts, partial sections, or patio-only. Custom cocktail packages available.',
    capacity: 'Up to 80 guests',
  },
  {
    slug: 'corporate-events',
    title: 'Corporate Events',
    desc: 'Company outings, client entertainment, team celebrations, and holiday parties. The only outdoor bar venue on Mission Blvd.',
    capacity: 'Up to 80 guests',
  },
  {
    slug: 'bachelorette-parties',
    title: 'Bachelorette Parties',
    desc: "Tropical cocktails, flamingo taps, pink umbrellas, and a patio steps from the beach. Miss B's was made for this.",
    capacity: 'Groups of any size',
  },
  {
    slug: 'full-venue-buyouts',
    title: 'Full Venue Buyouts',
    desc: "Take over the entire Miss B's Coconut Club — bar, dining room, and patio. The ultimate Mission Beach private event experience.",
    capacity: 'Up to 80 guests',
  },
  {
    slug: 'rehearsal-dinners',
    title: 'Rehearsal Dinners',
    desc: 'Casual-upscale, beach-adjacent, Caribbean-inspired. A rehearsal dinner that your guests will remember as the best meal of the weekend.',
    capacity: 'Up to 60 seated',
  },
  {
    slug: 'milestone-celebrations',
    title: 'Milestone Celebrations',
    desc: 'Anniversaries, retirements, graduations, and every other reason to gather people you love in a room worth being in.',
    capacity: 'Flexible configurations',
  },
];
---

<Layout
  title="Private Events and Venue Buyouts in Mission Beach | Miss B's Coconut Club"
  description="Host your private event at Miss B's Coconut Club in Mission Beach, San Diego. Birthday parties, corporate events, bachelorette parties, and full venue buyouts at 3704 Mission Blvd."
>

  <!-- HERO — venue-03 outdoor patio shot, strong for events context -->
  <section class="relative min-h-[80vh] flex items-end overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp"
      alt="Miss B's Coconut Club private events outdoor patio Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-top"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/85 via-coastal-text-main/30 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-16 md:pb-24">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral mb-4">
        Mission Beach&apos;s Premier Outdoor Event Venue
      </p>
      <h1 class="font-serif text-5xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.95] mb-4">
        Private Events
      </h1>
      <p class="text-coastal-bg-card/80 text-base max-w-xl leading-relaxed">
        The only open-air bar venue on Mission Blvd. Steps from the Pacific. Available for buyouts, parties, and corporate events of all sizes.
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-coastal-text-main">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-coastal-bg-pure/10">
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">80+</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Max Capacity</span>
        </div>
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">3 Spaces</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Configurable Areas</span>
        </div>
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">Custom</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Menu Options</span>
        </div>
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">24hr</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Response Time</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY MISS B'S — venue-14 fresh image -->
  <section class="bg-coastal-bg-pure">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[660px]">
      <div class="relative min-h-[460px] lg:min-h-full">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-14.webp"
          alt="Miss B's Coconut Club private event space Mission Beach San Diego"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col justify-center px-10 py-20 lg:px-16 xl:px-20 gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Why Miss B&apos;s</p>
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]">
          A Venue Worth<br />Showing Off
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed">
          Miss B&apos;s Coconut Club is not a banquet room. It&apos;s a genuinely memorable space &mdash; the open-air teal bar, the copper flamingo taps, the tropical dining room, the patio with pink fringed umbrellas. Your guests will be talking about the venue before they even get to the food.
        </p>
        <p class="text-coastal-text-muted text-base leading-relaxed">
          Our events team handles every detail from first inquiry to last call. Custom menus, cocktail packages, room configuration, and dedicated staff throughout your event.
        </p>
        <a href="/contact" class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
          Submit an Inquiry
        </a>
      </div>
    </div>
  </section>

  <!-- EVENT TYPES GRID -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Browse by Event Type</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">
          Every Occasion,<br />Handled
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-coastal-text-muted/10">
        {eventTypes.map((event) => (
          <a href={"/private-events/" + event.slug} class="group bg-coastal-bg-pure p-8 flex flex-col gap-4 hover:bg-coastal-bg-card transition-colors duration-200">
            <h3 class="font-serif text-2xl font-light italic text-coastal-text-main group-hover:text-coastal-coral transition-colors duration-200">
              {event.title}
            </h3>
            <div class="h-px w-10 bg-coastal-coral"></div>
            <p class="text-coastal-text-muted text-sm leading-relaxed flex-1">{event.desc}</p>
            <div class="flex items-center justify-between mt-2">
              <span class="text-xs text-coastal-text-muted">{event.capacity}</span>
              <span class="text-xs font-bold tracking-[0.15em] uppercase text-coastal-coral group-hover:translate-x-1 transition-transform duration-200">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-coastal-text-main py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">How It Works</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-bg-pure leading-[1.0]">
          From Inquiry<br />to Your Event
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-px bg-coastal-bg-pure/10">
        {[
          { step: '01', title: 'Submit an Inquiry',      body: 'Tell us your date, headcount, and event type. We respond within 24 hours.' },
          { step: '02', title: 'Custom Proposal',        body: 'We build a tailored proposal &mdash; menu options, space configuration, cocktail packages, and pricing.' },
          { step: '03', title: 'Confirm the Details',    body: 'Finalize the agreement and refine every detail &mdash; dietary needs, custom cocktails, room setup.' },
          { step: '04', title: 'Your Event',             body: 'Show up and enjoy it. Our team handles everything from setup to last call.' },
        ].map((item) => (
          <div class="bg-coastal-text-main p-8 flex flex-col gap-4">
            <span class="font-mono text-xs text-coastal-coral/50 tracking-[0.2em]">{item.step}</span>
            <h3 class="font-serif text-2xl font-light italic text-coastal-bg-pure">{item.title}</h3>
            <p class="text-coastal-text-muted text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — venue-11 fresh image not used elsewhere -->
  <section class="relative overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-11.webp"
      alt="Miss B's Coconut Club private event venue Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-coastal-text-main/70"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 py-24 text-center flex flex-col items-center gap-6">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
        Let&apos;s Make It Happen
      </p>
      <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.0]">
        Ready to Plan Your Event?
      </h2>
      <p class="text-coastal-bg-card/80 text-base max-w-lg leading-relaxed">
        Our events team responds within 24 hours with availability and a custom proposal.
      </p>
      <div class="flex flex-wrap gap-4 justify-center mt-2">
        <a href="/contact" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          Submit an Inquiry
        </a>
        <a href="/space" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
          View the Space
        </a>
      </div>
    </div>
  </section>

</Layout>
