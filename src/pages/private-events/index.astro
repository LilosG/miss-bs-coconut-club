---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SplitSection from '../../components/ui/SplitSection.astro';
import StatBar from '../../components/ui/StatBar.astro';
import { getCollection, getEntry } from 'astro:content';

const page = (await getEntry('privateEventsIndexPage', 'private-events'))!.data;
const eventTypes = (await getCollection('privateEventTypes'))
  .map((entry) => entry.data)
  .sort((a, b) => page.types.order.indexOf(a.slug) - page.types.order.indexOf(b.slug));
const processSteps = (await getCollection('privateEventsProcessSteps')).sort((a, b) => a.data.step.localeCompare(b.data.step)).map((entry) => entry.data);
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
>

  <PageHero
    imageSrc={page.hero.imageSrc}
    imageAlt={page.hero.imageAlt}
    eyebrow={page.hero.eyebrow}
    heading={page.hero.heading}
    subheading={page.hero.subheading}
    imagePosition="top"
  />

  <!-- STATS -->
  <StatBar items={page.stats} />

  <!-- WHY MISS B'S — venue-14 fresh image -->
  <SplitSection
    imageSrc={page.why.imageSrc}
    imageAlt={page.why.imageAlt}
    eyebrow={page.why.eyebrow}
    heading={page.why.heading}
    imageLeft={true}
  >
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.why.body[0]}\n`} />
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.why.body[1]}\n`} />
    <a href={page.why.cta.href} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.why.cta.label}\n`} />
  </SplitSection>

  <!-- EVENT TYPES GRID -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.types.eyebrow}</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.types.heading.replaceAll('<br />', '<br>')}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-coastal-text-muted/10">
        {eventTypes.map((event) => (
          <a href={"/private-events/" + event.slug} class="group bg-coastal-bg-pure p-8 flex flex-col gap-4 hover:bg-coastal-bg-card transition-colors duration-200">
            <h3 class="font-serif text-2xl font-light italic text-coastal-text-main group-hover:text-coastal-coral transition-colors duration-200">
              {event.title}
            </h3>
            <div class="h-px w-10 bg-coastal-coral"></div>
            <p class="text-coastal-text-muted text-sm leading-relaxed flex-1">{event.cardDesc}</p>
            <div class="flex items-center justify-between mt-2">
              <span class="text-xs text-coastal-text-muted">{event.capacity}</span>
              <span class="text-xs font-bold tracking-[0.15em] uppercase text-coastal-coral group-hover:translate-x-1 transition-transform duration-200" set:html={page.types.learnMore} />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-coastal-text-main py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.process.eyebrow}</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-bg-pure leading-[1.0]" set:html={`\n${page.process.heading.replaceAll('<br />', '<br>')}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-px bg-coastal-bg-pure/10">
        {processSteps.map((item) => (
          <div class="bg-coastal-text-main p-8 flex flex-col gap-4">
            <span class="font-mono text-xs text-coastal-coral/50 tracking-[0.2em]">{item.step}</span>
            <h3 class="font-serif text-2xl font-light italic text-coastal-bg-pure">{item.title}</h3>
            <p class="text-coastal-text-muted text-sm leading-relaxed" set:html={item.body} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EVENT INQUIRY FORM -->
  <section class="bg-coastal-bg-sand py-24 px-6" id="inquiry">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col gap-4 mb-10">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral" set:html={page.inquiry.eyebrow} />
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.inquiry.heading}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed max-w-lg" set:html={`\n${page.inquiry.body}\n`} />
      </div>
      <iframe
        src="https://www.toasttab.com/invoice/lead?rx=e5c781b0-3ef7-4e6e-acaa-f50c55b15f70&ot=555d2efd-aea1-4bef-ac04-17793cda7ded&form=1"
        style="margin:auto;display:block;border:0;width:100%;height:800px"
        title={page.inquiry.iframeTitle}
        loading="lazy"
      ></iframe>
    </div>
  </section>

</Layout>
