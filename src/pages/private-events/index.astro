---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import SplitSection from '../../components/ui/SplitSection.astro';
import CtaBand from '../../components/ui/CtaBand.astro';
import StatBar from '../../components/ui/StatBar.astro';
import eventsData from '../../data/events.json';
import siteProfile from '../../data/site-profile.json';

const eventTypes = Object.values(eventsData);
---

<Layout
  title="Private Events and Venue Buyouts in Mission Beach | Miss B's Coconut Club"
  description="Host your private event at Miss B's Coconut Club in Mission Beach, San Diego. Birthday parties, corporate events, bachelorette parties, and full venue buyouts at 3704 Mission Blvd."
>

  <PageHero
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp"
    imageAlt="Miss B's Coconut Club private events outdoor patio Mission Beach San Diego"
    eyebrow="Mission Beach&apos;s Premier Outdoor Event Venue"
    heading="Private Events"
    subheading="The only open-air bar venue on Mission Blvd. Steps from the Pacific. Available for buyouts, parties, and corporate events of all sizes."
    imagePosition="top"
  />

  <!-- STATS -->
  <StatBar items={[
    { value: '80+',      label: 'Max Capacity' },
    { value: '3 Spaces', label: 'Configurable Areas' },
    { value: 'Custom',   label: 'Menu Options' },
    { value: '24hr',     label: 'Response Time' },
  ]} />

  <!-- WHY MISS B'S — venue-14 fresh image -->
  <SplitSection
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-14.webp"
    imageAlt="Miss B's Coconut Club private event space Mission Beach San Diego"
    eyebrow="Why Miss B&apos;s"
    heading="A Venue Worth<br />Showing Off"
    imageLeft={true}
  >
    <p class="text-coastal-text-muted text-base leading-relaxed">
      Miss B&apos;s Coconut Club is not a banquet room. It&apos;s a genuinely memorable space &mdash; the open-air teal bar, the copper flamingo taps, the tropical dining room, the patio with pink fringed umbrellas. Your guests will be talking about the venue before they even get to the food.
    </p>
    <p class="text-coastal-text-muted text-base leading-relaxed">
      Our events team handles every detail from first inquiry to last call. Custom menus, cocktail packages, room configuration, and dedicated staff throughout your event.
    </p>
    <a href="/contact" class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
      Submit an Inquiry
    </a>
  </SplitSection>

  <!-- EVENT TYPES GRID -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Browse by Event Type</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">
          Every Occasion,<br />Handled
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-coastal-text-muted/10">
        {eventTypes.map((event) => (
          <a href={"/private-events/" + event.slug} class="group bg-coastal-bg-pure p-8 flex flex-col gap-4 hover:bg-coastal-bg-card transition-colors duration-200">
            <h3 class="font-serif text-2xl font-light italic text-coastal-text-main group-hover:text-coastal-coral transition-colors duration-200">
              {event.title}
            </h3>
            <div class="h-px w-10 bg-coastal-coral"></div>
            <p class="text-coastal-text-muted text-sm leading-relaxed flex-1">{event.cardDesc}</p>
            <div class="flex items-center justify-between mt-2">
              <span class="text-xs text-coastal-text-muted">{event.capacity}</span>
              <span class="text-xs font-bold tracking-[0.15em] uppercase text-coastal-coral group-hover:translate-x-1 transition-transform duration-200">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-coastal-text-main py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">How It Works</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-bg-pure leading-[1.0]">
          From Inquiry<br />to Your Event
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-px bg-coastal-bg-pure/10">
        {siteProfile.eventProcess.map((item) => (
          <div class="bg-coastal-text-main p-8 flex flex-col gap-4">
            <span class="font-mono text-xs text-coastal-coral/50 tracking-[0.2em]">{item.step}</span>
            <h3 class="font-serif text-2xl font-light italic text-coastal-bg-pure">{item.title}</h3>
            <p class="text-coastal-text-muted text-sm leading-relaxed" set:html={item.body} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — venue-11 fresh image not used elsewhere -->
  <CtaBand
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-11.webp"
    imageAlt="Miss B's Coconut Club private event venue Mission Beach San Diego"
    eyebrow="Let's Make It Happen"
    heading="Ready to Plan Your Event?"
    body="Our events team responds within 24 hours with availability and a custom proposal."
  >
    <a href="/contact" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
      Submit an Inquiry
    </a>
    <a href="/space" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
      View the Space
    </a>
  </CtaBand>

</Layout>
