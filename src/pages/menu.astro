---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
---

<Layout
  title="Menu - Food, Cocktails and Brunch | Miss B's Coconut Club Mission Beach"
  description="The full menu at Miss B's Coconut Club in Mission Beach, San Diego. Craft cocktails, Caribbean-inspired food, brunch plates, and more at 3704 Mission Blvd."
>

  <PageHero
    imageSrc="/images/food/miss-bs-coconut-club-food-mission-beach-17.webp"
    imageAlt="Miss B's Coconut Club food spread Mission Beach San Diego"
    eyebrow="Food &middot; Cocktails &middot; Brunch"
    heading="The Menu"
    subheading="Caribbean-inspired plates, craft cocktails, and weekend brunch at 3704 Mission Blvd, Mission Beach."
    minHeight="70vh"
  />

  <!-- CATEGORY CARDS -->
  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-14">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          What We&apos;re Serving
        </p>
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]">
          Explore the Menu
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-coastal-bg-card">
        {[
          {
            label: 'Food',
            desc: 'Caribbean-inspired plates built for sharing. Coconut shrimp, jerk chicken, the Coconut Club Burger, and a rotating selection of seasonal plates.',
            image: '/images/food/miss-bs-coconut-club-food-mission-beach-09.webp',
            alt: "Miss B's Coconut Club food menu Mission Beach San Diego",
          },
          {
            label: 'Cocktails',
            desc: 'Tropical craft cocktails from our full bar program. The Caribe Welcome, Mango Guava Spritz, Rum Cannonball, and 24 flamingo draft taps.',
            image: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-13.webp',
            alt: "Miss B's Coconut Club craft cocktails Mission Beach San Diego",
          },
          {
            label: 'Brunch',
            desc: 'Weekend brunch every Saturday and Sunday from 10am to 3pm. Bottomless mimosas, morning cocktails, and brunch plates worth getting out of bed for.',
            image: '/images/food/miss-bs-coconut-club-food-mission-beach-20.webp',
            alt: "Miss B's Coconut Club brunch Mission Beach San Diego",
          },
        ].map((cat) => (
          <div class="bg-coastal-bg-pure flex flex-col">
            <div class="relative overflow-hidden aspect-[4/3]">
              <img src={cat.image} alt={cat.alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex flex-col gap-4 p-8 flex-1">
              <h3 class="font-serif text-3xl font-light italic text-coastal-text-main">{cat.label}</h3>
              <div class="h-px w-10 bg-coastal-coral"></div>
              <p class="text-coastal-text-muted text-sm leading-relaxed flex-1">{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOD GRID — 8 unique images, none repeated from homepage -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-12">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">The Kitchen</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">Food</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
        {[
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-02.webp', name: 'Ahi Poke Bowl' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-04.webp', name: 'Coconut Shrimp' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-06.webp', name: 'Fish and Chips' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-10.webp', name: 'Jerk Chicken Wrap' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-15.webp', name: 'Jerk Wings' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-18.webp', name: 'Nachos' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-22.webp', name: 'Summer Salad' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-28.webp', name: 'Vacay Bowl' },
        ].map((item) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.src}
              alt={"Miss B's Coconut Club " + item.name + " Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-xs font-bold tracking-[0.15em] uppercase text-coastal-bg-pure">{item.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COCKTAIL GRID — 8 images, different from homepage cocktail grid -->
  <section class="bg-coastal-text-main py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-4 mb-12">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">The Bar</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-bg-pure leading-[1.0]">Cocktails</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
        {[
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-30.webp', name: 'Flamingo Bar' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-03.webp', name: 'Caribe Welcome' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-20.webp', name: 'Rose and Champagne' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-12.webp', name: 'Bloody Mary' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-09.webp', name: 'Watermelon Cocktail' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-11.webp', name: 'Signature Cocktail' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-35.webp', name: 'Tropical Cocktail' },
          { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-39.webp', name: 'Craft Cocktail' },
        ].map((item) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.src}
              alt={"Miss B's Coconut Club " + item.name + " cocktail Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-xs font-bold tracking-[0.15em] uppercase text-coastal-bg-pure">{item.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRUNCH CTA BAND -->
  <section class="grid grid-cols-1 lg:grid-cols-2 min-h-[480px]">
    <div class="relative min-h-[360px] lg:min-h-full">
      <img
        src="/images/venue/miss-bs-coconut-club-mission-beach-venue-09.webp"
        alt="Miss B's Coconut Club brunch bar Mission Beach San Diego"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-coastal-text-main/20"></div>
    </div>
    <div class="bg-coastal-coral flex flex-col justify-center px-10 py-16 lg:px-16 xl:px-20 gap-5">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-text-main/60">
        Saturday &amp; Sunday &middot; 10am &ndash; 3pm
      </p>
      <h2 class="font-serif text-4xl md:text-5xl font-light italic text-coastal-text-main leading-[1.0]">
        Weekend Brunch
      </h2>
      <div class="h-px w-16 bg-coastal-text-main/30"></div>
      <p class="text-coastal-text-main/80 text-base leading-relaxed max-w-[40ch]">
        Bottomless mimosas, morning cocktails, and the best brunch plates in Mission Beach.
      </p>
      <a href="/brunch" class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
        Brunch Details
      </a>
    </div>
  </section>

</Layout>
