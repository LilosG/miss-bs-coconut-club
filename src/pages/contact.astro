---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import PageHero from '../components/ui/PageHero.astro';
import SplitSection from '../components/ui/SplitSection.astro';

const siteProfile = (await getEntry('siteSettings', 'site'))!.data;
const page = (await getEntry('contactPage', 'contact'))!.data;
const mapsURL = "https://www.google.com/maps/search/?api=1&query=" + siteProfile.address.streetAddress + " " + siteProfile.address.addressLocality + " " + siteProfile.address.addressRegion;
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
>

  <PageHero
    imageSrc={page.hero.imageSrc}
    imageAlt={page.hero.imageAlt}
    eyebrow={page.hero.eyebrow}
    heading={page.hero.heading}
    minHeight="60vh"
  />

  <!-- ─── CONTACT GRID ─────────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 md:grid-cols-3 gap-px bg-coastal-bg-card">

      <!-- Reservations -->
      {page.cards?.[0] && <div class="bg-coastal-bg-pure p-10 flex flex-col gap-5">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.cards[0].eyebrow}</p>
        <h2 class="font-serif text-3xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.cards[0].heading}\n`} />
        <div class="h-px w-12 bg-coastal-coral"></div>
        {page.cards[0].body && <p class="text-coastal-text-muted text-sm leading-relaxed flex-1" set:html={`\n${page.cards[0].body}\n`} />}
        <a href={"tel:" + siteProfile.phone} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
          {siteProfile.phone}
        </a>
      </div>}

      <!-- Private Events -->
      {page.cards?.[1] && <div class="bg-coastal-bg-pure p-10 flex flex-col gap-5">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.cards[1].eyebrow}</p>
        <h2 class="font-serif text-3xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.cards[1].heading}\n`} />
        <div class="h-px w-12 bg-coastal-coral"></div>
        {page.cards[1].body && <p class="text-coastal-text-muted text-sm leading-relaxed flex-1" set:html={`\n${page.cards[1].body}\n`} />}
        {typeof page.cards[1].cta === 'object' && page.cards[1].cta && <a href={page.cards[1].cta.href} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.cards[1].cta.label}\n`} />}
      </div>}

      <!-- Location -->
      {page.cards?.[2] && <div class="bg-coastal-bg-pure p-10 flex flex-col gap-5">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.cards[2].eyebrow}</p>
        <h2 class="font-serif text-3xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.cards[2].heading}\n`} />
        <div class="h-px w-12 bg-coastal-coral"></div>
        <address class="not-italic flex flex-col gap-1 text-coastal-text-muted text-sm flex-1">
          <span>{siteProfile.address.streetAddress}</span>
          <span>{siteProfile.address.addressLocality}, {siteProfile.address.addressRegion} {siteProfile.address.postalCode}</span>
        </address>
        {typeof page.cards[2].cta === 'object' && page.cards[2].cta && <a href={mapsURL} target="_blank" rel="noopener noreferrer" class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.cards[2].cta.label}\n`} />}
      </div>}

    </div>
  </section>

  <!-- ─── EVENT INQUIRY FORM ──────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6" id="inquiry">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col gap-4 mb-10">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.inquiry.eyebrow}</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.inquiry.heading}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed max-w-lg" set:html={`\n${page.inquiry.body}\n`} />
      </div>
      <iframe
        src="https://www.toasttab.com/invoice/lead?rx=e5c781b0-3ef7-4e6e-acaa-f50c55b15f70&ot=555d2efd-aea1-4bef-ac04-17793cda7ded&form=1"
        style="margin:auto;display:block;border:0;width:100%;height:800px"
        title={page.inquiry.iframeTitle}
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <!-- ─── HOURS + MAP SPLIT ─────────────────────────────────────────────── -->
  <SplitSection
    imageSrc={page.hours.imageSrc}
    imageAlt={page.hours.imageAlt}
    eyebrow={page.hours.eyebrow}
    heading={page.hours.heading}
    sectionBg="bg-coastal-bg-sand"
    minHeight="500px"
    headingSize="medium"
  >
    <dl class="flex flex-col divide-y divide-coastal-text-muted/10">
      {(siteProfile.hours?.general ?? []).map((item: { label: string; display: string }) => (
        <div class="flex justify-between items-center py-4 gap-8">
          <dt class="text-sm text-coastal-text-muted">{item.label}</dt>
          <dd class="text-sm font-semibold text-coastal-text-main">{item.display}</dd>
        </div>
      ))}
    </dl>
    <div class="pt-2 flex flex-col gap-1">
      {page.hours.notes?.[0] && <p class="text-xs text-coastal-coral font-semibold tracking-wide">{page.hours.notes[0]}</p>}
      {page.hours.notes?.[1] && <p class="text-xs text-coastal-coral font-semibold tracking-wide">{page.hours.notes[1]}</p>}
    </div>
  </SplitSection>

  <!-- ─── SOCIAL ────────────────────────────────────────────────────────── -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.social.eyebrow}</p>
        <p class="font-serif text-4xl font-light italic text-coastal-bg-pure" set:html={`\n${page.social.heading}\n`} />
        <p class="text-coastal-text-muted text-sm" set:html={`\n${page.social.body}\n`} />
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        {page.social.links?.[0] && <a href={siteProfile.social.instagram} target="_blank" rel="noopener noreferrer"
           class="px-8 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200"
           set:html={`\n${page.social.links[0].label}\n`}
        />}
        {page.social.links?.[1] && <a href={siteProfile.social.facebook} target="_blank" rel="noopener noreferrer"
           class="px-8 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200"
           set:html={`\n${page.social.links[1].label}\n`}
        />}
      </div>
    </div>
  </section>

</Layout>
