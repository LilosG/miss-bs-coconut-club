---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import SplitSection from '../components/ui/SplitSection.astro';
import HoverImageGrid from '../components/ui/HoverImageGrid.astro';
import CtaBand from '../components/ui/CtaBand.astro';
import StatBar from '../components/ui/StatBar.astro';
import { getCollection, getEntry } from 'astro:content';

const page = (await getEntry('brunchPage', 'brunch'))!.data;
const brunchFaqs = (await getCollection('brunchFaqs')).map((entry) => entry.data);
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
>

  <PageHero
    imageSrc={page.hero.imageSrc}
    imageAlt={page.hero.imageAlt}
    eyebrow={page.hero.eyebrow}
    heading={page.hero.heading}
    subheading={page.hero.subheading}
  />

  <!-- STATS -->
  <StatBar items={page.stats} />

  <SplitSection
    imageSrc={page.experience.imageSrc}
    imageAlt={page.experience.imageAlt}
    eyebrow={page.experience.eyebrow}
    heading={page.experience.heading}
  >
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.experience.body[0]}\n`} />
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.experience.body[1]}\n`} />
    <div class="flex flex-wrap gap-4 mt-2">
      <a href={page.experience.ctas[0].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.experience.ctas[0].label}\n`} />
      <a href={page.experience.ctas[1].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.experience.ctas[1].label}\n`} />
    </div>
  </SplitSection>

  <!-- BRUNCH FOOD GRID — 6 unique brunch plates, no duplicates -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-12">
        <div class="flex flex-col gap-4">
          <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.food.eyebrow}</p>
          <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.food.heading.replaceAll('<br />', '<br>')}\n`} />
          <div class="h-px w-16 bg-coastal-coral"></div>
        </div>
        <a href={page.food.cta.href} class="shrink-0 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.food.cta.label}\n`} />
      </div>
      <HoverImageGrid
        cols="2x3"
        gap={true}
        items={page.food.grid}
      />
    </div>
  </section>

  <!-- COCKTAIL FEATURE — cocktail-34: mimosas lined up at flamingo tap bar -->
  <section class="relative overflow-hidden min-h-[600px] flex items-center">
    <img
      src={page.cocktails.imageSrc}
      alt={page.cocktails.imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main/88 via-coastal-text-main/55 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-20">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral" set:html={`\n${page.cocktails.eyebrow}\n`} />
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.0]" set:html={`\n${page.cocktails.heading.replaceAll('<br />', '<br>')}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/85 text-base leading-relaxed" set:html={`\n${page.cocktails.body}\n`} />
      </div>
    </div>
  </section>

  <!-- BRUNCH COCKTAIL GRID — 4 brunch drink shots -->
  <section class="bg-coastal-text-main">
    <HoverImageGrid
      showLabel={false}
      items={page.cocktails.grid}
    />
  </section>

  <!-- FAQ -->
  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="flex flex-col gap-4">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.faq.eyebrow}</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">{page.faq.heading}</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed mt-2" set:html={`\n${page.faq.body}\n`} />
      </div>
      <dl class="flex flex-col divide-y divide-coastal-text-muted/10">
        {brunchFaqs.map((faq) => (
          <div class="py-5">
            <dt class="font-sans text-sm font-semibold text-coastal-text-main mb-2">{faq.q}</dt>
            <dd class="font-sans text-sm text-coastal-text-muted leading-relaxed">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA BAND -->
  <CtaBand
    imageSrc={page.cta.imageSrc}
    imageAlt={page.cta.imageAlt}
    imagePosition="top"
    eyebrow={page.cta.eyebrow}
    heading={page.cta.heading}
    body={page.cta.body}
  >
    <a href={page.cta.links[0].href} class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.cta.links[0].label}\n`} />
    <a href={page.cta.links[1].href} class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300" set:html={`\n${page.cta.links[1].label}\n`} />
  </CtaBand>

</Layout>
