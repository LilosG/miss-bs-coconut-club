---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';
---

<Layout
  title="Weekend Brunch in Mission Beach San Diego | Miss B's Coconut Club"
  description="Weekend brunch at Miss B's Coconut Club in Mission Beach, San Diego. Saturday and Sunday 10am-3pm. Bottomless mimosas, tropical cocktails, and the best brunch plates on Mission Blvd."
>

  <!-- HERO -->
  <section class="relative min-h-[80vh] flex items-end overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-07.webp"
      alt="Miss B's Coconut Club brunch Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/85 via-coastal-text-main/30 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-16 md:pb-24">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral mb-4">
        Saturday &amp; Sunday &middot; 10am &ndash; 3pm
      </p>
      <h1 class="font-serif text-5xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.95] mb-4">
        Weekend Brunch<br />in Mission Beach
      </h1>
      <p class="text-coastal-bg-card/80 text-base max-w-xl leading-relaxed">
        Miss B&apos;s Coconut Club is Mission Beach&apos;s favorite weekend ritual. Open every Saturday and Sunday from 10am to 3pm.
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-coastal-text-main">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-coastal-bg-pure/10">
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">10am</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Doors Open</span>
        </div>
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">3pm</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Last Call</span>
        </div>
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">Sat &amp; Sun</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Every Weekend</span>
        </div>
        <div class="flex flex-col items-center justify-center py-8 px-4 gap-1">
          <span class="font-serif text-2xl font-light italic text-coastal-coral">Bottomless</span>
          <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-bg-card/60">Mimosas Available</span>
        </div>
      </div>
    </div>
  </section>

  <!-- BRUNCH EXPERIENCE SPLIT -->
  <section class="bg-coastal-bg-pure">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[660px]">
      <div class="flex flex-col justify-center px-10 py-20 lg:px-16 xl:px-20 gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          The Brunch Experience
        </p>
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]">
          Mission Beach&apos;s<br />Best Weekend Ritual
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed">
          Miss B&apos;s Coconut Club does not do brunch halfway. The full kitchen is open, the bar is pouring, and the outdoor patio is yours. Steps from the Pacific at 3704 Mission Blvd.
        </p>
        <p class="text-coastal-text-muted text-base leading-relaxed">
          Bottomless mimosas, tropical morning cocktails, and a menu built for a long, indulgent weekend afternoon. Walk-ins welcome. Reservations recommended.
        </p>
        <div class="flex flex-wrap gap-4 mt-2">
          <a href="/contact" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
            Make a Reservation
          </a>
          <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
            View Brunch Menu
          </a>
        </div>
      </div>
      <div class="relative min-h-[460px] lg:min-h-full">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-08.webp"
          alt="Miss B's Coconut Club brunch interior Mission Beach San Diego"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- COCKTAILS FEATURE -->
  <section class="relative overflow-hidden min-h-[560px] flex items-center">
    <img
      src="/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-34.webp"
      alt="Miss B's Coconut Club mimosas and brunch cocktails Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main/90 via-coastal-text-main/60 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-20">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          Brunch Cocktails
        </p>
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.0]">
          Bottomless Mimosas<br />&amp; Morning Cocktails
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/85 text-base leading-relaxed">
          Bottomless mimosas, tropical morning cocktails, and the full Miss B&apos;s bar program available from 10am every Saturday and Sunday.
        </p>
      </div>
    </div>
  </section>

  <!-- BRUNCH FOOD GRID — all fresh images not used on homepage -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-12">
        <div class="flex flex-col gap-4">
          <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
            Brunch Menu
          </p>
          <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]">
            Plates Worth<br />Getting Out of Bed For
          </h2>
          <div class="h-px w-16 bg-coastal-coral"></div>
        </div>
        <a href="/menu" class="shrink-0 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Full Menu
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        {[
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-03.webp', name: 'Easy Bs Breakfast' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-41.webp', name: 'Veggie Breakfast Sandwich' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-05.webp', name: 'Chips and Guac' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-19.webp', name: 'Coconut Club Burger' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-23.webp', name: 'Jerk Wrap' },
          { src: '/images/food/miss-bs-coconut-club-food-mission-beach-30.webp', name: 'Group Plates' },
        ].map((item) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.src}
              alt={"Miss B's Coconut Club " + item.name + " brunch Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-bg-pure">{item.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="flex flex-col gap-4">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Good to Know</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">Brunch FAQ</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed mt-2">
          Everything you need to know before you show up Saturday morning.
        </p>
      </div>
      <dl class="flex flex-col divide-y divide-coastal-text-muted/10">
        {[
          { q: 'What are brunch hours?', a: 'Every Saturday and Sunday from 10am to 3pm. Last seating at 2:30pm.' },
          { q: 'Do you offer bottomless mimosas?', a: 'Yes. Bottomless mimosas are available during brunch service. Ask your server for details.' },
          { q: 'Do I need a reservation?', a: 'Walk-ins are welcome but we strongly recommend reservations for weekend brunch, especially on Sundays.' },
          { q: 'Is the patio open for brunch?', a: 'Yes. The full outdoor patio and bar area is open for brunch service weather permitting.' },
          { q: 'Is the full bar open during brunch?', a: 'The full bar program is available from 10am including tropical cocktails, beer, and wine.' },
        ].map((faq) => (
          <div class="py-5">
            <dt class="font-sans text-sm font-semibold text-coastal-text-main mb-2">{faq.q}</dt>
            <dd class="font-sans text-sm text-coastal-text-muted leading-relaxed">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="relative overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp"
      alt="Miss B's Coconut Club outdoor patio Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-top"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-coastal-text-main/70"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 py-24 text-center flex flex-col items-center gap-6">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Every Saturday &amp; Sunday</p>
      <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.0]">
        Brunch Starts at 10am
      </h2>
      <p class="text-coastal-bg-card/80 text-base max-w-lg leading-relaxed">
        3704 Mission Blvd, Mission Beach, San Diego. Walk-ins welcome. Reservations recommended.
      </p>
      <div class="flex flex-wrap gap-4 justify-center mt-2">
        <a href="/contact" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          Reserve a Table
        </a>
        <a href="/menu" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
          View the Menu
        </a>
      </div>
    </div>
  </section>

</Layout>
