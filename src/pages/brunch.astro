---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/ui/PageHero.astro';
import SplitSection from '../components/ui/SplitSection.astro';
import HoverImageGrid from '../components/ui/HoverImageGrid.astro';
import CtaBand from '../components/ui/CtaBand.astro';
import StatBar from '../components/ui/StatBar.astro';
import siteProfile from '../data/site-profile.json';
import menuData from '../data/menu.json';
---

<Layout
  title="Brunch in Mission Beach San Diego | Miss B's Coconut Club"
  description="Brunch at Miss B's Coconut Club in Mission Beach, San Diego. Served daily until 2pm. Bottomless mimosas, tropical cocktails, and the best brunch plates on Mission Blvd."
>

  <PageHero
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-07.webp"
    imageAlt="Miss B's Coconut Club brunch Mission Beach San Diego"
    eyebrow="Served Daily &middot; Until 2pm"
    heading="Brunch<br />in Mission Beach"
    subheading="Miss B's Coconut Club serves brunch every day of the week. Doors open at 10am Friday through Sunday, 11am Monday through Thursday, and brunch service runs until 2pm."
  />

  <!-- STATS -->
  <StatBar items={[
    { value: '10/11am',    label: 'Doors Open' },
    { value: '2pm',        label: 'Last Call' },
    { value: 'Daily',      label: 'Every Day' },
    { value: 'Bottomless', label: 'Mimosas Available' },
  ]} />

  <SplitSection
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-08.webp"
    imageAlt="Miss B's Coconut Club brunch interior Mission Beach San Diego"
    eyebrow="The Brunch Experience"
    heading="Mission Beach&apos;s<br />Best Weekend Ritual"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed">
      Miss B&apos;s Coconut Club does not do brunch halfway. The full kitchen is open, the bar is pouring, and the outdoor patio is yours. Steps from the Pacific at 3704 Mission Blvd.
    </p>
    <p class="text-coastal-text-muted text-base leading-relaxed">
      Bottomless mimosas, tropical morning cocktails, and a menu built for a long, indulgent afternoon. Walk-ins welcome. Reservations recommended.
    </p>
    <div class="flex flex-wrap gap-4 mt-2">
      <a href="/contact" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
        Make a Reservation
      </a>
      <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
        View Brunch Menu
      </a>
    </div>
  </SplitSection>

  <!-- BRUNCH FOOD GRID — 6 unique brunch plates, no duplicates -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-12">
        <div class="flex flex-col gap-4">
          <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Brunch Menu</p>
          <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]">
            Plates Worth<br />Getting Out of Bed For
          </h2>
          <div class="h-px w-16 bg-coastal-coral"></div>
        </div>
        <a href="/menu" class="shrink-0 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Full Menu
        </a>
      </div>
      <HoverImageGrid
        cols="2x3"
        gap={true}
        items={menuData.brunchPageGrids.food}
      />
    </div>
  </section>

  <!-- COCKTAIL FEATURE — cocktail-34: mimosas lined up at flamingo tap bar -->
  <section class="relative overflow-hidden min-h-[600px] flex items-center">
    <img
      src="/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-34.webp"
      alt="Miss B's Coconut Club bottomless mimosas at flamingo tap bar Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main/88 via-coastal-text-main/55 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-20">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          Brunch Cocktails
        </p>
        <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.0]">
          Bottomless Mimosas<br />&amp; Morning Cocktails
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/85 text-base leading-relaxed">
          Bottomless mimosas poured in front of 24 copper flamingo taps. Tropical morning cocktails, Bloody Marys, and the full Miss B&apos;s bar program available daily during brunch hours.
        </p>
      </div>
    </div>
  </section>

  <!-- BRUNCH COCKTAIL GRID — 4 brunch drink shots -->
  <section class="bg-coastal-text-main">
    <HoverImageGrid
      showLabel={false}
      items={menuData.brunchPageGrids.cocktails}
    />
  </section>

  <!-- FAQ -->
  <section class="bg-coastal-bg-pure py-24 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="flex flex-col gap-4">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Good to Know</p>
        <h2 class="font-serif text-5xl font-light italic text-coastal-text-main leading-[1.0]">Brunch FAQ</h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-base leading-relaxed mt-2">
          Everything you need to know before you show up.
        </p>
      </div>
      <dl class="flex flex-col divide-y divide-coastal-text-muted/10">
        {siteProfile.brunchFaq.map((faq) => (
          <div class="py-5">
            <dt class="font-sans text-sm font-semibold text-coastal-text-main mb-2">{faq.q}</dt>
            <dd class="font-sans text-sm text-coastal-text-muted leading-relaxed">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA BAND -->
  <CtaBand
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp"
    imageAlt="Miss B's Coconut Club outdoor patio Mission Beach San Diego"
    imagePosition="top"
    eyebrow="Served Daily"
    heading="Brunch, Every Day"
    body="3704 Mission Blvd, Mission Beach, San Diego. Walk-ins welcome. Reservations recommended."
  >
    <a href="/contact" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
      Reserve a Table
    </a>
    <a href="/menu" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
      View the Menu
    </a>
  </CtaBand>

</Layout>
