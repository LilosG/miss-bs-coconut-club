---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'best-brunch-mission-beach',
    title: 'The Best Brunch in Mission Beach, San Diego',
    excerpt: 'Mission Beach has no shortage of brunch spots. Here\'s why Miss B\'s Coconut Club consistently earns the top spot — and what to order when you get there.',
    category: 'Mission Beach Guide',
    date: '2025-05-10',
    image: '/images/venue/miss-bs-coconut-club-mission-beach-venue-07.webp',
    imageAlt: 'Miss B\'s Coconut Club brunch Mission Beach San Diego',
  },
  {
    slug: 'best-bars-mission-beach',
    title: 'Best Bars in Mission Beach San Diego',
    excerpt: 'A guide to the best bars in Mission Beach — from the boardwalk to Mission Blvd. Miss B\'s Coconut Club leads the list for good reason.',
    category: 'Mission Beach Guide',
    date: '2025-04-18',
    image: '/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp',
    imageAlt: 'Miss B\'s Coconut Club open-air bar Mission Beach San Diego',
  },
  {
    slug: 'private-events-mission-beach',
    title: 'Private Event Venues in Mission Beach: A Complete Guide',
    excerpt: 'Planning a birthday, bachelorette, or corporate event in Mission Beach? Here\'s everything you need to know — and why Miss B\'s is the obvious choice.',
    category: 'Private Events',
    date: '2025-03-22',
    image: '/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp',
    imageAlt: 'Miss B\'s Coconut Club private event patio Mission Beach',
  },
  {
    slug: 'things-to-do-mission-beach',
    title: 'Things to Do in Mission Beach San Diego',
    excerpt: 'A local guide to Mission Beach — what to do, where to eat, where to drink, and why Miss B\'s Coconut Club at 3704 Mission Blvd should be on every itinerary.',
    category: 'Mission Beach Guide',
    date: '2025-02-14',
    image: '/images/venue/miss-bs-coconut-club-mission-beach-venue-04.webp',
    imageAlt: 'Miss B\'s Coconut Club Mission Beach San Diego',
  },
  {
    slug: 'tropical-cocktails-san-diego',
    title: 'Best Tropical Cocktail Bars in San Diego',
    excerpt: 'San Diego\'s tropical cocktail scene has leveled up. Miss B\'s Coconut Club — with its 24 flamingo taps and Caribbean-rooted drink program — is setting the standard.',
    category: 'Food and Drink',
    date: '2025-01-08',
    image: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-13.webp',
    imageAlt: 'Miss B\'s Coconut Club tropical cocktails Mission Beach San Diego',
  },
  {
    slug: 'bachelorette-party-san-diego',
    title: 'Best Bachelorette Party Venues in San Diego',
    excerpt: 'Planning a bachelorette in San Diego? This guide covers the best venues by neighborhood — with Miss B\'s Coconut Club as the top pick for Mission Beach.',
    category: 'Private Events',
    date: '2024-12-05',
    image: '/images/venue/miss-bs-coconut-club-mission-beach-venue-13.webp',
    imageAlt: 'Miss B\'s Coconut Club bachelorette party venue Mission Beach San Diego',
  },
];
---

<Layout
  title="Blog — Mission Beach Guides, Events & Local Tips | Miss B's Coconut Club"
  description="The Miss B's Coconut Club blog — local guides to Mission Beach dining, San Diego bar recommendations, private event planning tips, and stories from our tropical kitchen and bar."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[60vh] flex items-end overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp"
      alt="Miss B's Coconut Club Mission Beach San Diego blog"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/85 via-coastal-text-main/30 to-transparent"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-16 md:pb-24">
      <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral mb-4">
        Stories, Guides &amp; Local Tips
      </p>
      <h1 class="font-serif text-5xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.95]">
        The Blog
      </h1>
    </div>
  </section>

  <!-- ─── POSTS GRID ────────────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-coastal-text-muted/10">
        {posts.map((post) => (
          <a href={"/blog/" + post.slug} class="group bg-coastal-bg-pure flex flex-col hover:bg-coastal-bg-card transition-colors duration-200">
            <div class="overflow-hidden aspect-[16/10]">
              <img
                src={post.image}
                alt={post.imageAlt}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col gap-3 p-7 flex-1">
              <div class="flex items-center justify-between gap-4">
                <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">{post.category}</span>
                <time datetime={post.date} class="text-xs text-coastal-text-muted">
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                </time>
              </div>
              <h2 class="font-serif text-xl font-light italic text-coastal-text-main group-hover:text-coastal-coral transition-colors duration-200 leading-snug flex-1">
                {post.title}
              </h2>
              <p class="text-coastal-text-muted text-sm leading-relaxed">{post.excerpt}</p>
              <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-coastal-coral group-hover:translate-x-1 transition-transform duration-200 inline-block mt-1">
                Read More →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-3">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Come Experience It</p>
        <p class="font-serif text-4xl font-light italic text-coastal-bg-pure">
          Miss B's Coconut Club
        </p>
        <p class="text-coastal-text-muted text-sm">3704 Mission Blvd · Mission Beach, San Diego</p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/contact" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Make a Reservation
        </a>
        <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          View the Menu
        </a>
      </div>
    </div>
  </section>

</Layout>
