---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CtaBand from '../../components/ui/CtaBand.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug);
if (!post) return Astro.redirect('/blog');

const { Content } = await render(post);
const page = (await getEntry('blogIndexPage', 'blog'))!.data;

const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Layout
  title={post.data.metaTitle}
  description={post.data.description}
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[60vh] flex flex-col justify-end overflow-hidden">
    <img
      src={post.data.image}
      alt={post.data.imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/95 via-coastal-text-main/50 to-coastal-text-main/10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 pb-16 pt-32 w-full">
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-4">
          <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-coastal-coral">{post.data.category}</span>
          <span class="text-coastal-bg-pure/30 text-xs">·</span>
          <time datetime={post.data.date} class="text-[10px] font-bold tracking-[0.2em] uppercase text-coastal-bg-pure/50">{formattedDate}</time>
        </div>
        <h1 class="font-serif text-4xl md:text-6xl font-light italic text-coastal-bg-pure leading-[1.05] max-w-3xl">
          {post.data.title}
        </h1>
        <p class="text-coastal-bg-card/75 text-base leading-relaxed max-w-2xl font-light">
          {post.data.description}
        </p>
      </div>
    </div>
  </section>

  <!-- ─── ARTICLE BODY ──────────────────────────────────────────────────── -->
  <article class="bg-coastal-bg-pure py-20 px-6">
    <div class="max-w-[72ch] mx-auto">
      <div class="prose">
        <Content />
      </div>
      <div class="pt-12 mt-12 border-t border-coastal-text-muted/10">
        <a href="/blog" class="inline-flex items-center gap-2 text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral hover:text-coastal-gold-accent transition-colors duration-200" set:html={`\n${page.postCta.backLabel}\n`} />
      </div>
    </div>
  </article>

  <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
  <CtaBand
    imageSrc={page.postCta.imageSrc}
    imageAlt={page.postCta.imageAlt}
    heading={page.postCta.heading}
    body={page.postCta.body}
    headingSize="medium"
    py="py-20"
    gap="gap-5"
  >
    <a href={page.postCta.links[0].href} class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.postCta.links[0].label}\n`} />
    <a href={page.postCta.links[1].href} class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300" set:html={`\n${page.postCta.links[1].label}\n`} />
  </CtaBand>

</Layout>
