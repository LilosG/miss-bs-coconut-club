---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import CtaBand from '../../components/ui/CtaBand.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug);
if (!post) return Astro.redirect('/blog');

const { Content } = await render(post);
---

<Layout
  title={post.data.metaTitle}
  description={post.data.description}
>

  <!-- ─── ARTICLE HERO ──────────────────────────────────────────────────── -->
  <PageHero
    imageSrc={post.data.image}
    imageAlt={post.data.imageAlt}
    eyebrow={post.data.category}
    heading={post.data.title}
    minHeight="60vh"
    overlayFrom="from-coastal-text-main/90"
    overlayVia="via-coastal-text-main/40"
    headingClass="text-4xl md:text-6xl"
    eyebrowMb="mb-3"
  >
    <time datetime={post.data.date} class="block text-xs text-coastal-bg-card/60 mt-4 tracking-wide">
      {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
    </time>
  </PageHero>

  <!-- ─── ARTICLE BODY ──────────────────────────────────────────────────── -->
  <article class="bg-coastal-bg-pure py-16 px-6">
    <div class="max-w-[68ch] mx-auto">

      <p class="font-sans text-coastal-text-muted text-base leading-relaxed italic border-b border-coastal-text-muted/10 pb-8 mb-8">
        {post.data.description}
      </p>

      <div class="prose prose-coastal">
        <Content />
      </div>

      <div class="pt-10 mt-10 border-t border-coastal-text-muted/10">
        <a href="/blog" class="inline-flex items-center gap-2 text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral hover:text-coastal-gold-accent transition-colors duration-200">
          ← Back to Blog
        </a>
      </div>

    </div>
  </article>

  <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
  <CtaBand
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp"
    imageAlt="Miss B's Coconut Club Mission Beach San Diego"
    heading="Come Experience It in Person"
    body="3704 Mission Blvd, Mission Beach, San Diego. Open daily."
    headingSize="medium"
    py="py-20"
    gap="gap-5"
  >
    <a href="/contact" class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
      Make a Reservation
    </a>
    <a href="/menu" class="px-8 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/50 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
      View the Menu
    </a>
  </CtaBand>

</Layout>
