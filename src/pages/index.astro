---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';

const mapsURL = "https://www.google.com/maps/search/?api=1&query=" + siteProfile.seo.streetAddress + " " + siteProfile.seo.addressLocality + " " + siteProfile.seo.addressRegion;

const cocktailGrid = [
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-03.webp', name: 'Caribe Welcome' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-32.webp', name: 'Mango Guava Spritz' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-02.webp', name: 'Bird is the Word' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-26.webp', name: 'Fiesta Island' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-37.webp', name: 'Rum Cannonball' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-38.webp', name: 'Spritz and Giggles' },
];

const foodGrid = [
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-09.webp', name: 'Coconut Club Burger' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-13.webp', name: 'Cubano' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-17.webp', name: 'Table Spread' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-26.webp', name: 'Jerk Plate' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-12.webp', name: 'Cubano Stacked' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-32.webp', name: 'Nachos' },
];
---

<Layout
  title="Bar and Brunch on Mission Blvd - Mission Beach San Diego"
  description="Miss Bs Coconut Club is Mission Beach San Diegos favorite outdoor bar and brunch spot. Craft cocktails, weekend brunch, and private events at 3704 Mission Blvd."
>

  <!-- HERO -->
  <section class="relative h-screen min-h-[680px] flex flex-col items-center justify-center overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp"
      alt="Miss Bs Coconut Club teal bar open window Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-black/15 to-black/45"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-6 text-center flex flex-col items-center gap-7">
      <p class="text-xs font-bold tracking-[0.35em] uppercase text-coastal-coral">
        3704 Mission Blvd - Mission Beach, San Diego
      </p>
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-[0.9] tracking-tight text-coastal-bg-pure italic">
        Miss Bs<br />
        <span class="italic text-coastal-coral">Coconut Club</span>
      </h1>
      <p class="max-w-lg text-base text-coastal-bg-card/90 leading-relaxed font-light tracking-wide">
        San Diegos open-air bar and brunch destination. Steps from the Pacific on Mission Blvd.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 mt-2">
        <a href="/menu" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          View the Menu
        </a>
        <a href="/brunch" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/60 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
          Weekend Brunch
        </a>
      </div>
    </div>

    <!-- Info strip pinned to bottom of hero -->
    <div class="absolute bottom-0 left-0 right-0 z-10 bg-coastal-text-main/80 backdrop-blur-md border-t border-coastal-bg-pure/10">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-coastal-bg-pure/10">
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Hours</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">Mon - Fri 11am to Close</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Brunch</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">Sat and Sun 10am - 3pm</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Find Us</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">Mission Beach, San Diego</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Reserve</span>
            <a href="/contact" class="text-xs text-coastal-gold-accent hover:text-coastal-bg-pure transition-colors tracking-wide">Book a Table</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EDITORIAL INTRO -->
  <section class="bg-coastal-bg-pure py-28 px-6">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="flex flex-col gap-7">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          Mission Beach, San Diego
        </p>
        <h2 class="font-serif text-6xl md:text-7xl font-light italic text-coastal-text-main leading-[0.9] tracking-tight">
          Where San Diego Comes to Drink Well
        </h2>
        <div class="h-px w-20 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-lg leading-relaxed">
          Miss Bs Coconut Club is the open-air bar and brunch spot that Mission Beach was built for. Pull up a teal stool at our outdoor bar, order something cold, and let the afternoon go.
        </p>
        <p class="text-coastal-text-muted leading-relaxed">
          Located at 3704 Mission Blvd, steps from the sand. Come for the craft cocktails. Stay for the brunch. Bring the whole group.
        </p>
        <div class="flex flex-wrap gap-4 mt-2">
          <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
            Full Menu
          </a>
          <a href="/space" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
            See the Space
          </a>
        </div>
      </div>
      <!-- Staggered image duo -->
      <div class="relative h-[600px] hidden lg:block">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-13.webp"
          alt="Miss Bs Coconut Club teal bar window open Mission Beach"
          class="absolute top-0 left-0 w-[62%] h-[420px] object-cover"
          loading="lazy"
        />
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-18.webp"
          alt="Miss Bs Coconut Club copper flamingo tap handles interior"
          class="absolute bottom-0 right-0 w-[62%] h-[380px] object-cover"
          loading="lazy"
        />
        <div class="absolute top-[200px] left-[50%] -translate-x-1/2 w-12 h-12 bg-coastal-coral z-10"></div>
      </div>
      <!-- Mobile single image -->
      <div class="lg:hidden">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-13.webp"
          alt="Miss Bs Coconut Club teal bar window open Mission Beach"
          class="w-full h-72 object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- COCKTAIL FEATURE — full bleed flamingo -->
  <section class="relative py-40 px-6 overflow-hidden bg-coastal-text-main">
    <div class="absolute inset-0 opacity-20">
      <img
        src="/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-13.webp"
        alt="Miss Bs Coconut Club signature flamingo cocktail vessel"
        class="w-full h-full object-cover object-center"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main via-coastal-text-main/80 to-transparent"></div>
    <div class="relative z-10 mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="flex flex-col gap-7">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          Craft Cocktails
        </p>
        <h2 class="font-serif text-6xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.9] tracking-tight">
          Signature Cocktails in Mission Beach
        </h2>
        <div class="h-px w-20 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/80 text-lg leading-relaxed">
          From the flamingo vessel to the frozen mojito, every drink at Miss Bs is built for the San Diego sun. Tropical, bold, and entirely unforgettable.
        </p>
        <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/30 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200 self-start">
          Full Drink Menu
        </a>
      </div>
      <div class="flex justify-center">
        <img
          src="/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-13.webp"
          alt="Miss Bs Coconut Club signature flamingo cocktail Mission Beach San Diego"
          class="w-full max-w-sm h-[520px] object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- COCKTAIL GRID -->
  <section class="bg-coastal-text-main pb-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        {cocktailGrid.map((cocktail, i) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={cocktail.src}
              alt={"Miss Bs Coconut Club " + cocktail.name + " cocktail Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/90 via-coastal-text-main/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-sm font-bold tracking-[0.15em] uppercase text-coastal-bg-pure">{cocktail.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRUNCH FEATURE -->
  <section class="relative overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[600px]">
      <div class="relative min-h-[400px] lg:min-h-full">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-09.webp"
          alt="Miss Bs Coconut Club copper flamingo tap handles Mission Beach"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-coastal-text-main/40"></div>
      </div>
      <div class="bg-coastal-coral flex flex-col justify-center px-12 py-20 gap-7">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-text-main/60">
          Saturday and Sunday
        </p>
        <h2 class="font-serif text-6xl font-light italic text-coastal-text-main leading-[0.9] tracking-tight">
          Weekend Brunch in Mission Beach
        </h2>
        <div class="h-px w-20 bg-coastal-text-main/30"></div>
        <p class="text-coastal-text-main/80 text-lg leading-relaxed">
          Every Saturday and Sunday from 10am to 3pm. Bottomless mimosas, morning cocktails, and the best brunch plates in Mission Beach.
        </p>
        <div class="flex flex-wrap gap-4 mt-2">
          <a href="/brunch" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
            Brunch Details
          </a>
          <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:bg-coastal-text-main hover:text-coastal-bg-pure transition-all duration-300">
            Brunch Menu
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOD SECTION -->
  <section class="bg-coastal-bg-sand py-28 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-16">
        <div class="flex flex-col gap-5">
          <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
            The Kitchen
          </p>
          <h2 class="font-serif text-6xl md:text-7xl font-black text-coastal-text-main uppercase leading-[0.9] tracking-tight">
            Food Worth<br />Staying For
          </h2>
          <div class="h-px w-20 bg-coastal-coral"></div>
        </div>
        <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200 shrink-0">
          View Full Menu
        </a>
      </div>
      <!-- Asymmetric food grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        {foodGrid.map((item, i) => (
          <div class={"group relative overflow-hidden " + (i === 0 ? "md:col-span-1 aspect-[3/4]" : "aspect-square")}>
            <img
              src={item.src}
              alt={"Miss Bs Coconut Club " + item.name + " Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-sm font-bold tracking-[0.15em] uppercase text-coastal-bg-pure">{item.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRIVATE EVENTS -->
  <section class="bg-coastal-bg-pure py-28 px-6 border-t border-coastal-text-muted/10">
    <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="flex flex-col gap-7">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          Private Events
        </p>
        <h2 class="font-serif text-6xl font-light italic text-coastal-text-main leading-[0.9] tracking-tight">
          Private Events in Mission Beach
        </h2>
        <div class="h-px w-20 bg-coastal-coral"></div>
        <p class="text-coastal-text-muted text-lg leading-relaxed">
          Birthdays, buyouts, corporate events and intimate gatherings. Miss Bs Coconut Club is the only open-air bar venue on Mission Blvd steps from the Pacific.
        </p>
        <ul class="flex flex-col gap-3 mt-2">
          {["Birthday Parties", "Full and Partial Buyouts", "Corporate Events", "Bachelor and Bachelorette", "Milestone Celebrations"].map(item => (
            <li class="flex items-center gap-4 text-sm text-coastal-text-muted">
              <div class="h-px w-6 bg-coastal-coral shrink-0"></div>
              {item}
            </li>
          ))}
        </ul>
        <a href="/private-events" class="mt-4 px-7 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300 self-start">
          Inquire About Your Event
        </a>
      </div>
      <div class="relative">
        <img
          src="/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp"
          alt="Miss Bs Coconut Club teal bar herringbone tile Mission Beach San Diego"
          class="w-full h-[560px] object-cover"
          loading="lazy"
        />
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-coastal-coral -z-10"></div>
      </div>
    </div>
  </section>

  <!-- LOCATION BAR -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Find Us</p>
        <p class="font-serif text-5xl font-light italic text-coastal-bg-pure tracking-tight">
          {siteProfile.seo.streetAddress}
        </p>
        <p class="text-coastal-text-muted text-sm tracking-wide">
          {siteProfile.seo.addressLocality}, {siteProfile.seo.addressRegion} {siteProfile.seo.postalCode}
        </p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href={"tel:" + siteProfile.seo.telephone} class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          {siteProfile.seo.telephone}
        </a>
        <a href="/contact" class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Make a Reservation
        </a>
        <a href={mapsURL} target="_blank" rel="noopener noreferrer" class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          Get Directions
        </a>
      </div>
    </div>
  </section>

</Layout>
