---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';
import SplitSection from '../components/ui/SplitSection.astro';
import HoverImageGrid from '../components/ui/HoverImageGrid.astro';

const mapsURL = "https://www.google.com/maps/search/?api=1&query=" + siteProfile.seo.streetAddress + " " + siteProfile.seo.addressLocality + " " + siteProfile.seo.addressRegion;

const cocktailGrid = [
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-03.webp', name: 'Caribe Welcome' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-32.webp', name: 'Mango Guava Spritz' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-02.webp', name: 'Bird is the Word' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-26.webp', name: 'Fiesta Island' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-37.webp', name: 'Rum Cannonball' },
  { src: '/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-38.webp', name: 'Spritz and Giggles' },
];

const foodRight = [
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-13.webp', name: 'Cubano' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-17.webp', name: 'Table Spread' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-26.webp', name: 'Jerk Plate' },
  { src: '/images/food/miss-bs-coconut-club-food-mission-beach-32.webp', name: 'Nachos' },
];
---

<Layout
  title="Bar and Brunch on Mission Blvd - Mission Beach San Diego"
  description="Miss B's Coconut Club is Mission Beach San Diego's favorite outdoor bar and brunch spot. Craft cocktails, weekend brunch, and private events at 3704 Mission Blvd."
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative h-screen min-h-[680px] flex flex-col items-center justify-center overflow-hidden">
    <img
      src="/images/venue/miss-bs-coconut-club-mission-beach-venue-15.webp"
      alt="Miss B's Coconut Club teal bar open window Mission Beach San Diego"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-black/15 to-black/45"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-6 text-center flex flex-col items-center gap-7">
      <p class="text-xs font-bold tracking-[0.35em] uppercase text-coastal-coral">
        3704 Mission Blvd · Mission Beach, San Diego
      </p>
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-[0.9] tracking-tight text-coastal-bg-pure italic">
        Miss B's<br />
        <span class="italic text-coastal-coral">Coconut Club</span>
      </h1>
      <p class="max-w-lg text-base text-coastal-bg-card/90 leading-relaxed font-light tracking-wide">
        San Diego's open-air bar and brunch destination. Steps from the Pacific on Mission Blvd.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 mt-2">
        <a href="/menu" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          View the Menu
        </a>
        <a href="/brunch" class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/60 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300">
          Weekend Brunch
        </a>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 z-10 bg-coastal-text-main/80 backdrop-blur-md border-t border-coastal-bg-pure/10">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-coastal-bg-pure/10">
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Hours</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">Mon – Fri 11am to Close</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Brunch</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">Sat &amp; Sun 10am – 3pm</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Find Us</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">Mission Beach, San Diego</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">Reserve</span>
            <a href="/contact" class="text-xs text-coastal-gold-accent hover:text-coastal-bg-pure transition-colors tracking-wide">Book a Table</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── EDITORIAL INTRO ───────────────────────────────────────────────── -->
  <SplitSection
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-07.webp"
    imageAlt="Miss B's Coconut Club tropical dining room with mural Mission Beach San Diego"
    eyebrow="Mission Beach, San Diego"
    heading="Where San Diego<br />Comes to Drink Well"
    imageLeft={true}
    minHeight="700px"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed">
      Miss B's Coconut Club is the open-air bar and brunch spot that Mission Beach was built for. Pull up a teal stool, order something cold, and let the afternoon go.
    </p>
    <p class="text-coastal-text-muted text-base leading-relaxed">
      Located at 3704 Mission Blvd — steps from the sand. Come for the craft cocktails. Stay for the brunch. Bring the whole group.
    </p>
    <div class="flex flex-wrap gap-4 mt-2">
      <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200">
        Full Menu
      </a>
      <a href="/space" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
        See the Space
      </a>
    </div>
  </SplitSection>

  <!-- ─── COCKTAIL FEATURE ──────────────────────────────────────────────── -->
  <!-- Gradient lightened: from-coastal-text-main/90 → to-transparent so image breathes on right -->
  <section class="relative overflow-hidden min-h-[680px] flex items-center">
    <img
      src="/images/cocktails/miss-bs-coconut-club-cocktail-mission-beach-13.webp"
      alt="Miss B's Coconut Club signature flamingo cocktail vessel Mission Beach"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main/90 via-coastal-text-main/60 to-transparent"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-24">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
          Craft Cocktails
        </p>
        <h2 class="font-serif text-5xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.95]">
          Signature<br />Cocktails in<br />Mission Beach
        </h2>
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/85 text-base leading-relaxed">
          From the flamingo vessel to the frozen mojito, every drink at Miss B's is built for the San Diego sun. Tropical, bold, and entirely unforgettable.
        </p>
        <a href="/menu" class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/30 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Full Drink Menu
        </a>
      </div>
    </div>
  </section>

  <!-- ─── COCKTAIL GRID ─────────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-pure">
    <HoverImageGrid
      cols="2x3"
      aspect="4/3"
      labelPadding="p-5"
      gradientFrom="from-coastal-text-main/75"
      items={cocktailGrid.map((c) => ({ src: c.src, name: c.name, alt: "Miss B's Coconut Club " + c.name + " cocktail Mission Beach San Diego" }))}
    />
  </section>

  <!-- ─── BRUNCH FEATURE ────────────────────────────────────────────────── -->
  <SplitSection
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-17.webp"
    imageAlt="Miss B's Coconut Club copper flamingo draft tap handles Mission Beach"
    eyebrow="Saturday &amp; Sunday"
    heading="Weekend Brunch<br />in Mission Beach"
    imageLeft={true}
    imageOverlay={true}
    minHeight="600px"
    variant="coral"
  >
    <p class="text-coastal-text-main/80 text-base leading-relaxed max-w-[44ch]">
      Every Saturday and Sunday from 10am to 3pm. Bottomless mimosas, morning cocktails, and the best brunch plates on Mission Blvd.
    </p>
    <div class="flex flex-wrap gap-4 mt-2">
      <a href="/brunch" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
        Brunch Details
      </a>
      <a href="/menu" class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/25 text-coastal-text-main hover:bg-coastal-text-main hover:text-coastal-bg-pure transition-all duration-300">
        Brunch Menu
      </a>
    </div>
  </SplitSection>

  <!-- ─── FOOD SECTION ──────────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-12">
        <div class="flex flex-col gap-4">
          <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">
            The Kitchen
          </p>
          <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]">
            Food Worth<br />Staying For
          </h2>
          <div class="h-px w-16 bg-coastal-coral"></div>
        </div>
        <a href="/menu" class="shrink-0 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          View Full Menu
        </a>
      </div>

      <div class="grid grid-cols-3 gap-2">
        <!-- Burger — full left column, spans 2 rows -->
        <div class="group relative overflow-hidden row-span-2">
          <img
            src="/images/food/miss-bs-coconut-club-food-mission-beach-09.webp"
            alt="Miss B's Coconut Club Coconut Club Burger Mission Beach San Diego"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            <p class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-bg-pure">Coconut Club Burger</p>
          </div>
        </div>
        <!-- Right 4 items — 2x2 -->
        {foodRight.map((item) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.src}
              alt={"Miss B's Coconut Club " + item.name + " Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-bg-pure">{item.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PRIVATE EVENTS ────────────────────────────────────────────────── -->
  <SplitSection
    imageSrc="/images/venue/miss-bs-coconut-club-mission-beach-venue-03.webp"
    imageAlt="Miss B's Coconut Club outdoor patio pink umbrellas Mission Beach San Diego private events"
    eyebrow="Private Events"
    heading="Private Events<br />in Mission Beach"
    imagePosition="top"
    minHeight="620px"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed max-w-[44ch]">
      Birthdays, buyouts, corporate events, and intimate gatherings. Miss B's Coconut Club is the only open-air bar venue on Mission Blvd — steps from the Pacific.
    </p>
    <ul class="flex flex-col gap-2.5 mt-2">
      {["Birthday Parties", "Full and Partial Buyouts", "Corporate Events", "Bachelor and Bachelorette", "Milestone Celebrations"].map((item) => (
        <li class="flex items-center gap-4 text-sm text-coastal-text-muted">
          <div class="h-px w-5 bg-coastal-coral shrink-0"></div>
          {item}
        </li>
      ))}
    </ul>
    <a href="/private-events" class="self-start mt-4 px-7 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
      Inquire About Your Event
    </a>
  </SplitSection>

  <!-- ─── LOCATION BAR ──────────────────────────────────────────────────── -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">Find Us</p>
        <p class="font-serif text-4xl md:text-5xl font-light italic text-coastal-bg-pure tracking-tight">
          {siteProfile.seo.streetAddress}
        </p>
        <p class="text-coastal-text-muted text-sm tracking-wide">
          {siteProfile.seo.addressLocality}, {siteProfile.seo.addressRegion} {siteProfile.seo.postalCode}
        </p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href={"tel:" + siteProfile.seo.telephone} class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          {siteProfile.seo.telephone}
        </a>
        <a href="/contact" class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          Make a Reservation
        </a>
        <a href={mapsURL} target="_blank" rel="noopener noreferrer" class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300">
          Get Directions
        </a>
      </div>
    </div>
  </section>

</Layout>
