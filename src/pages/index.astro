---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import SplitSection from '../components/ui/SplitSection.astro';
import HoverImageGrid from '../components/ui/HoverImageGrid.astro';
import ChecklistItems from '../components/ui/ChecklistItems.astro';

const siteProfile = (await getEntry('siteSettings', 'site'))!.data;
const page = (await getEntry('home', 'home'))!.data;
const mapsURL = "https://www.google.com/maps/search/?api=1&query=" + siteProfile.address.streetAddress + " " + siteProfile.address.addressLocality + " " + siteProfile.address.addressRegion;

const cocktailGrid = page.cocktailGrid;
const foodRight    = page.food.grid;

const happyHourActive = siteProfile.hours.happyHour.find((h: { closed?: boolean }) => !h.closed);
const happyHourOffDays = siteProfile.hours.happyHour.find((h: { closed?: boolean }) => h.closed);
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative h-screen min-h-[680px] flex flex-col items-center justify-center overflow-hidden">
    <img
      src={page.hero.imageSrc}
      alt={page.hero.imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-black/15 to-black/45"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-6 text-center flex flex-col items-center gap-7">
      <p class="text-xs font-bold tracking-[0.35em] uppercase text-coastal-coral" set:html={`\n${page.hero.eyebrow}\n`} />
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-[0.9] tracking-tight text-coastal-bg-pure italic" set:html={`\n${page.hero.heading}<br> <span class="italic text-coastal-coral">${page.hero.headingAccent}</span> `} />
      <p class="max-w-lg text-base text-coastal-bg-card/90 leading-relaxed font-light tracking-wide" set:html={`\n${page.hero.subheading}\n`} />
      <div class="flex flex-wrap items-center justify-center gap-4 mt-2">
        <a href={page.hero.ctas[0].href} class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.hero.ctas[0].label}\n`} />
        <a href={page.hero.ctas[1].href} class="px-10 py-4 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/60 text-coastal-bg-pure hover:bg-coastal-bg-pure hover:text-coastal-text-main transition-all duration-300" set:html={`\n${page.hero.ctas[1].label}\n`} />
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 z-10 bg-coastal-text-main/80 backdrop-blur-md border-t border-coastal-bg-pure/10">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-coastal-bg-pure/10">
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">{page.hero.stats[0].label}</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed" set:html={page.hero.stats[0].value} />
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">{page.hero.stats[1].label}</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">{page.hero.stats[1].value}</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">{page.hero.stats[2].label}</span>
            <span class="text-xs text-coastal-bg-card text-center leading-relaxed">{page.hero.stats[2].value}</span>
          </div>
          <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
            <span class="text-[10px] font-bold tracking-[0.25em] uppercase text-coastal-coral">{page.hero.stats[3].label}</span>
            <a href={page.hero.stats[3].href} class="text-xs text-coastal-gold-accent hover:text-coastal-bg-pure transition-colors tracking-wide">{page.hero.stats[3].value}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── EDITORIAL INTRO ───────────────────────────────────────────────── -->
  <SplitSection
    imageSrc={page.intro.imageSrc}
    imageAlt={page.intro.imageAlt}
    eyebrow={page.intro.eyebrow}
    heading={page.intro.heading}
    imageLeft={true}
    minHeight="700px"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.intro.body[0]}\n`} />
    <p class="text-coastal-text-muted text-base leading-relaxed" set:html={`\n${page.intro.body[1]}\n`} />
    <div class="flex flex-wrap gap-4 mt-2">
      <a href={page.intro.ctas[0].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-200" set:html={`\n${page.intro.ctas[0].label}\n`} />
      <a href={page.intro.ctas[1].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.intro.ctas[1].label}\n`} />
    </div>
  </SplitSection>

  <!-- ─── COCKTAIL FEATURE ──────────────────────────────────────────────── -->
  <!-- Gradient lightened: from-coastal-text-main/90 → to-transparent so image breathes on right -->
  <section class="relative overflow-hidden min-h-[680px] flex items-center">
    <img
      src={page.cocktailFeature.imageSrc}
      alt={page.cocktailFeature.imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-coastal-text-main/90 via-coastal-text-main/60 to-transparent"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-24">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral" set:html={`\n${page.cocktailFeature.eyebrow}\n`} />
        <h2 class="font-serif text-5xl md:text-7xl font-light italic text-coastal-bg-pure leading-[0.95]" set:html={`\n${page.cocktailFeature.heading.replaceAll('<br />', '<br>')}\n`} />
        <div class="h-px w-16 bg-coastal-coral"></div>
        <p class="text-coastal-bg-card/85 text-base leading-relaxed" set:html={`\n${page.cocktailFeature.body}\n`} />
        <a href={page.cocktailFeature.cta.href} class="self-start px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/30 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.cocktailFeature.cta.label}\n`} />
      </div>
    </div>
  </section>

  <!-- ─── COCKTAIL GRID ─────────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-pure">
    <HoverImageGrid
      cols="2x3"
      aspect="4/3"
      labelPadding="p-5"
      gradientFrom="from-coastal-text-main/75"
      items={cocktailGrid.map((c: { src: string; name: string }) => ({ src: c.src, name: c.name, alt: "Miss B's Coconut Club " + c.name + " cocktail Mission Beach San Diego" }))}
    />
  </section>

  <!-- ─── HAPPY HOUR ─────────────────────────────────────────────────────── -->
  <SplitSection
    imageSrc={page.happyHour.imageSrc}
    imageAlt={page.happyHour.imageAlt}
    eyebrow={happyHourActive?.label ?? ''}
    heading={page.happyHour.heading}
    minHeight="600px"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed max-w-[44ch]" set:html={`\n${happyHourActive ? `${page.happyHour.bodyPrefix}${happyHourActive.display}, ${happyHourActive.label}${page.happyHour.bodyMiddle}${happyHourOffDays ? `${page.happyHour.offDaysPrefix}${happyHourOffDays.label}.` : ''}` : ''} `} />
    <div class="flex flex-wrap gap-4 mt-2">
      <a href={page.happyHour.ctas[0].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.happyHour.ctas[0].label}\n`} />
      <a href={page.happyHour.ctas[1].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/25 text-coastal-text-main hover:bg-coastal-text-main hover:text-coastal-bg-pure transition-all duration-300" set:html={`\n${page.happyHour.ctas[1].label}\n`} />
    </div>
  </SplitSection>

  <!-- ─── BRUNCH FEATURE ────────────────────────────────────────────────── -->
  <SplitSection
    imageSrc={page.brunch.imageSrc}
    imageAlt={page.brunch.imageAlt}
    eyebrow={page.brunch.eyebrow}
    heading={page.brunch.heading}
    imageLeft={true}
    imageOverlay={true}
    minHeight="600px"
    variant="coral"
  >
    <p class="text-coastal-text-main/80 text-base leading-relaxed max-w-[44ch]" set:html={`\n${page.brunch.body}\n`} />
    <div class="flex flex-wrap gap-4 mt-2">
      <a href={page.brunch.ctas[0].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.brunch.ctas[0].label}\n`} />
      <a href={page.brunch.ctas[1].href} class="px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/25 text-coastal-text-main hover:bg-coastal-text-main hover:text-coastal-bg-pure transition-all duration-300" set:html={`\n${page.brunch.ctas[1].label}\n`} />
    </div>
  </SplitSection>

  <!-- ─── FOOD SECTION ──────────────────────────────────────────────────── -->
  <section class="bg-coastal-bg-sand py-24 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-12">
        <div class="flex flex-col gap-4">
          <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral" set:html={`\n${page.food.eyebrow}\n`} />
          <h2 class="font-serif text-5xl md:text-6xl font-light italic text-coastal-text-main leading-[1.0]" set:html={`\n${page.food.heading.replaceAll('<br />', '<br>')}\n`} />
          <div class="h-px w-16 bg-coastal-coral"></div>
        </div>
        <a href={page.food.cta.href} class="shrink-0 px-7 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-text-main/30 text-coastal-text-main hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.food.cta.label}\n`} />
      </div>

      <div class="grid grid-cols-3 gap-2">
        <!-- Burger — full left column, spans 2 rows -->
        <div class="group relative overflow-hidden row-span-2">
          <img
            src={page.food.featured.src}
            alt={page.food.featured.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            <p class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-bg-pure">{page.food.featured.name}</p>
          </div>
        </div>
        <!-- Right 4 items — 2x2 -->
        {foodRight.map((item: { src: string; name: string }) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.src}
              alt={"Miss B's Coconut Club " + item.name + " Mission Beach San Diego"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coastal-text-main/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-xs font-bold tracking-[0.2em] uppercase text-coastal-bg-pure">{item.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PRIVATE EVENTS ────────────────────────────────────────────────── -->
  <SplitSection
    imageSrc={page.privateEvents.imageSrc}
    imageAlt={page.privateEvents.imageAlt}
    eyebrow={page.privateEvents.eyebrow}
    heading={page.privateEvents.heading}
    imagePosition="top"
    minHeight="620px"
  >
    <p class="text-coastal-text-muted text-base leading-relaxed max-w-[44ch]" set:html={`\n${page.privateEvents.body}\n`} />
    <ChecklistItems items={page.privateEvents.items} />
    <a href={page.privateEvents.cta.href} class="self-start mt-4 px-7 py-4 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-text-main text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.privateEvents.cta.label}\n`} />
  </SplitSection>

  <!-- ─── LOCATION BAR ──────────────────────────────────────────────────── -->
  <section class="bg-coastal-text-main py-20 px-6">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-3 text-center md:text-left">
        <p class="text-[10px] font-bold tracking-[0.35em] uppercase text-coastal-coral">{page.location.eyebrow}</p>
        <p class="font-serif text-4xl md:text-5xl font-light italic text-coastal-bg-pure tracking-tight">
          {siteProfile.address.streetAddress}
        </p>
        <p class="text-coastal-text-muted text-sm tracking-wide">
          {siteProfile.address.addressLocality}, {siteProfile.address.addressRegion} {siteProfile.address.postalCode}
        </p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href={"tel:" + siteProfile.phone} class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200">
          {siteProfile.phone}
        </a>
        <a href={page.location.reservation.href} class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase border border-coastal-bg-pure/20 text-coastal-bg-pure hover:border-coastal-coral hover:text-coastal-coral transition-all duration-200" set:html={`\n${page.location.reservation.label}\n`} />
        <a href={mapsURL} target="_blank" rel="noopener noreferrer" class="px-6 py-3.5 text-xs font-bold tracking-[0.2em] uppercase bg-coastal-coral text-coastal-bg-pure hover:bg-coastal-gold-accent transition-all duration-300" set:html={`\n${page.location.directionsLabel}\n`} />
      </div>
    </div>
  </section>

</Layout>
